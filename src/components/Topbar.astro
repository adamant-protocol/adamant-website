---
import { PAGES, HEADER_PAGES, PHASE, SOCIAL_LINKS } from '@/data/chain';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
---

<header class="topbar" role="banner" id="topbar">
  <div class="topbar-row">
    <a class="brand" href="/" aria-label="Adamant home">
      <img class="mark" src="/adm-mark.svg" alt="Adamant" />
      <span class="brand-meta">Protocol</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {HEADER_PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
        >{p.label}</a>
      ))}
    </nav>

    <div class="phase-pill" data-phase={PHASE.key}>
      <span>{PHASE.shortLabel}</span>
    </div>

    <button
      class="nav-toggle"
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="nav-toggle-label">Menu</span>
    </button>
  </div>

  <!-- Drawer overlays the entire viewport (incl. the topbar) when open.
       Its own head row mirrors the topbar so there is no visible gap. -->
  <div class="nav-drawer" id="nav-drawer" inert>
    <div class="nav-drawer-head">
      <a class="brand" href="/" aria-label="Adamant home">
        <img class="mark" src="/adm-mark.svg" alt="Adamant" />
        <span class="brand-meta">Protocol</span>
      </a>
      <button class="nav-drawer-close" type="button" id="nav-drawer-close" aria-label="Close menu">
        <svg viewBox="0 0 14 14" width="14" height="14" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" aria-hidden="true">
          <path d="M1 1L13 13M13 1L1 13"/>
        </svg>
        <span>Close</span>
      </button>
    </div>

    <nav aria-label="Mobile primary">
      {PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
        >
          <span class="nav-drawer-label">{p.label}</span>
          <span class="nav-drawer-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <div class="nav-drawer-rail">
      <span class="label">Connect</span>
      <div class="nav-drawer-socials">
        <a href={SOCIAL_LINKS.github} rel="noopener" target="_blank" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.27 1.98-.405 3-.405 1.02 0 2.04.135 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.66 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.895-.015 3.285 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
        <a href={SOCIAL_LINKS.x} rel="noopener" target="_blank" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="nav-drawer-backdrop" id="nav-drawer-backdrop" aria-hidden="true"></div>
</header>
