---
import { PAGES, HEADER_PAGES, PHASE, SOCIAL_LINKS } from '@/data/chain';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
---

<header class="topbar" role="banner" id="topbar">
  <div class="topbar-row">
    <a class="brand" href="/" aria-label="Adamant home">
      <img class="mark" src="/adm-mark.svg" alt="Adamant" />
      <span class="brand-meta">Protocol</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {HEADER_PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
          {...(('external' in p && p.external) ? { rel: 'noopener', target: '_blank' } : {})}
        >{p.label}</a>
      ))}
    </nav>

    <div class="phase-pill" data-phase={PHASE.key}>
      <span>{PHASE.shortLabel}</span>
    </div>

    <button
      class="nav-toggle"
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="nav-toggle-label">Menu</span>
    </button>
  </div>

  <div class="nav-drawer" id="nav-drawer" inert>
    <nav aria-label="Mobile primary">
      {PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
        >
          <span class="nav-drawer-label">{p.label}</span>
          <span class="nav-drawer-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <div class="nav-drawer-rail">
      <span class="label">Connect</span>
      <div class="nav-drawer-socials">
        <a href={SOCIAL_LINKS.github} rel="noopener" target="_blank" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
            <path d="M12 .297C5.373.297 0 5.67 0 12.297c0 5.302 3.438 9.8 8.205 11.385.6.111.82-.26.82-.577 0-.286-.011-1.04-.016-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.418-1.305.762-1.605-2.665-.302-5.467-1.332-5.467-5.93 0-1.31.467-2.382 1.235-3.222-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.5 11.5 0 0 1 3.003-.404c1.018.005 2.045.137 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.654 1.652.243 2.873.12 3.176.77.84 1.232 1.911 1.232 3.222 0 4.61-2.807 5.625-5.479 5.92.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .319.218.694.825.576C20.565 22.092 24 17.594 24 12.297 24 5.67 18.627.297 12 .297z"/>
          </svg>
        </a>
        <a href={SOCIAL_LINKS.x} rel="noopener" target="_blank" aria-label="X">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="nav-drawer-foot">
      <span class="phase-pill" data-phase={PHASE.key}><span>{PHASE.shortLabel}</span></span>
      <span>Protocol &middot; spec v0.1</span>
    </div>
  </div>
</header>
