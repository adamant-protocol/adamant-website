---
import { PAGES, HEADER_PAGES, PHASE, SOCIAL_LINKS } from '@/data/chain';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
---

<header class="topbar" role="banner" id="topbar">
  <div class="topbar-row">
    <a class="brand" href="/" aria-label="Adamant home">
      <img class="mark" src="/adm-mark.svg" alt="Adamant" />
      <span class="brand-meta">Protocol</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {HEADER_PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
        >{p.label}</a>
      ))}
    </nav>

    <div class="phase-pill" data-phase={PHASE.key}>
      <span>{PHASE.shortLabel}</span>
    </div>

    <button
      class="nav-toggle"
      type="button"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="nav-toggle-bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="nav-toggle-label">Menu</span>
    </button>
  </div>

  <!-- Drawer overlays the entire viewport (incl. the topbar) when open.
       Its own head row mirrors the topbar so there is no visible gap. -->
  <div class="nav-drawer" id="nav-drawer" inert>
    <div class="nav-drawer-head">
      <a class="brand" href="/" aria-label="Adamant home">
        <img class="mark" src="/adm-mark.svg" alt="Adamant" />
        <span class="brand-meta">Protocol</span>
      </a>
      <button class="nav-drawer-close" type="button" id="nav-drawer-close" aria-label="Close menu">
        <svg viewBox="0 0 14 14" width="14" height="14" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" aria-hidden="true">
          <path d="M1 1L13 13M13 1L1 13"/>
        </svg>
        <span>Close</span>
      </button>
    </div>

    <nav aria-label="Mobile primary">
      {PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
        >
          <span class="nav-drawer-label">{p.label}</span>
          <span class="nav-drawer-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </nav>

    <div class="nav-drawer-rail">
      <span class="label">Connect</span>
      <div class="nav-drawer-socials">
        <a href={SOCIAL_LINKS.github} rel="noopener" target="_blank" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a href={SOCIAL_LINKS.x} rel="noopener" target="_blank" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="nav-drawer-foot">
      <span class="phase-pill" data-phase={PHASE.key}><span>{PHASE.shortLabel}</span></span>
      <span>Protocol &middot; spec v0.1</span>
    </div>
  </div>
</header>
