---
import { PAGES, PHASE } from '@/data/chain';

interface Props {
  active?: string;
}
const { active = 'home' } = Astro.props;
---

<header class="topbar" role="banner">
  <div class="topbar-row">
    <a class="brand" href="/" aria-label="Adamant home">
      <img class="mark" src="/adm-logo-square.svg" alt="" aria-hidden="true" />
      <span>Adamant</span>
      <span class="brand-meta">Protocol · v0.1</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {PAGES.map((p) => (
        <a
          href={p.href}
          class:list={[p.k === active ? 'is-current' : '']}
          {...(('external' in p && p.external) ? { rel: 'noopener', target: '_blank' } : {})}
        >{p.label}</a>
      ))}
    </nav>
    <div class="phase-pill" data-phase={PHASE.key}>
      <span>{PHASE.shortLabel}</span>
    </div>
  </div>
</header>
