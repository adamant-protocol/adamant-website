---
// Repository pulse — fetched at build time from the GitHub API.
// Surfaces stars, contributors, commit cadence, latest tag, languages.
type Repo = { stargazers_count: number; subscribers_count: number; open_issues_count: number; default_branch: string; description: string; html_url: string };
type Contributor = { login: string; contributions: number };
type Commit = { sha: string; commit: { author: { date: string } } };
type Tag = { name: string; commit: { sha: string } };

const OWNER = 'adamant-protocol';
const REPOS = ['adamant-website', 'adamant-spec', 'adamant-node'];

const headers: Record<string, string> = {
  Accept: 'application/vnd.github+json',
  'X-GitHub-Api-Version': '2022-11-28',
  'User-Agent': 'adamant-website-build',
};
if (process.env.GITHUB_TOKEN) headers.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;

async function safeFetch<T>(url: string): Promise<T | null> {
  try {
    const r = await fetch(url, { headers });
    if (!r.ok) return null;
    return await r.json() as T;
  } catch { return null; }
}

const repos = await Promise.all(REPOS.map(async (name) => {
  const repo = await safeFetch<Repo>(`https://api.github.com/repos/${OWNER}/${name}`);
  const commits = await safeFetch<Commit[]>(`https://api.github.com/repos/${OWNER}/${name}/commits?per_page=20`);
  const contribs = await safeFetch<Contributor[]>(`https://api.github.com/repos/${OWNER}/${name}/contributors?per_page=100`);
  const tags = await safeFetch<Tag[]>(`https://api.github.com/repos/${OWNER}/${name}/tags?per_page=1`);
  return {
    name,
    repo,
    commits: commits ?? [],
    contribs: contribs ?? [],
    latestTag: tags && tags[0] ? tags[0].name : null,
  };
}));

function freshness(c: Commit[]): string {
  if (!c.length) return '—';
  const last = new Date(c[0].commit.author.date).getTime();
  const days = Math.floor((Date.now() - last) / (86400 * 1000));
  if (days === 0) return 'today';
  if (days === 1) return '1 day ago';
  return `${days} days ago`;
}
---
<div class="pulse-grid">
  {repos.map((r) => (
    <article class="pulse-card">
      <header class="pulse-head">
        <span class="mono" style="font-size: 10.5px; letter-spacing: 0.14em; color: var(--ink-3);">REPO</span>
        <a class="serif" style="font-size: 22px; line-height: 1.1; letter-spacing: -0.01em; color: var(--ink); display:block; margin-top: 4px;" href={r.repo?.html_url ?? '#'} rel="noopener" target="_blank">{r.name}</a>
        {r.repo?.description && <p class="serif small" style="margin-top: 6px; color: var(--ink-2); max-width: 50ch;">{r.repo.description}</p>}
      </header>
      <dl class="pulse-stats">
        <div><dt>Stars</dt><dd class="mono">{r.repo?.stargazers_count ?? '—'}</dd></div>
        <div><dt>Watchers</dt><dd class="mono">{r.repo?.subscribers_count ?? '—'}</dd></div>
        <div><dt>Open issues</dt><dd class="mono">{r.repo?.open_issues_count ?? '—'}</dd></div>
        <div><dt>Contributors</dt><dd class="mono">{r.contribs.length || '—'}</dd></div>
        <div><dt>Last commit</dt><dd class="mono">{freshness(r.commits)}</dd></div>
        <div><dt>Latest tag</dt><dd class="mono">{r.latestTag ?? '—'}</dd></div>
      </dl>
    </article>
  ))}
</div>

<style>
  .pulse-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }
  .pulse-card {
    padding: 20px 18px;
    border-left: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--paper);
  }
  .pulse-card:first-child { border-left: 0; }
  .pulse-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 18px; margin: auto 0 0; padding-top: 14px; border-top: 1px solid var(--rule); }
  .pulse-stats div { display: flex; justify-content: space-between; gap: 8px; }
  .pulse-stats dt { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3); }
  .pulse-stats dd { margin: 0; font-size: 13.5px; color: var(--ink); }
  @media (max-width: 980px) {
    .pulse-grid { grid-template-columns: 1fr; }
    .pulse-card { border-left: 0; border-top: 1px solid var(--rule); }
    .pulse-card:first-child { border-top: 0; }
  }
</style>
