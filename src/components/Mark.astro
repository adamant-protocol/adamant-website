---
/**
 * The Adamant mark — uses adm-logo-square.svg (square-cropped from the master SVG).
 *
 * Sizing:
 *   <Mark />               — default 48px
 *   <Mark size={64} />     — explicit pixel size
 *   <Mark size="100%" />   — fill parent
 */
interface Props {
  size?: number | string;
  class?: string;
}

const { size = 48, class: classProp = '' } = Astro.props;
const sizePx = typeof size === 'number' ? `${size}px` : size;
---

<img
  src="/adm-logo-square.svg"
  alt="Adamant"
  class:list={['inline-block shrink-0 align-middle select-none', classProp]}
  style={`width:${sizePx};height:${sizePx}`}
  decoding="async"
  loading="eager"
/>
