---
import Mark from './Mark.astro';

const GITHUB = 'https://github.com/adamant-protocol/adamant';
---

<footer class="relative z-[5] mt-[200px] border-t border-rule px-0 py-24 pb-12">
  <div class="wrap">
    <div class="mb-24 grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-20 lg:grid-cols-[2.2fr_1fr_1fr_1fr]">
      <div class="md:col-span-2 lg:col-span-1">
        <p class="max-w-[30ch] font-display text-[24px] leading-[1.4] tracking-[-0.02em] text-ink">
          <span class="font-light text-ink-2">Adamant has no team page</span><br />
          by design.<br />
          <span class="font-light text-ink-2">The protocol is what you trust.</span>
        </p>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Protocol</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="/spec" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Whitepaper</a></li>
          <li><a href="/genesis" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Genesis</a></li>
          <li><a href={GITHUB} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Reference impl</a></li>
          <li><a href="/about" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">About</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Code</h4>
        <ul class="flex flex-col gap-3">
          <li><a href={GITHUB} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">GitHub</a></li>
          <li><a href={`${GITHUB}/issues`} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Issues</a></li>
          <li><a href={`${GITHUB}/discussions`} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Discussions</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Project</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="/updates" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Updates</a></li>
          <li><a href="/rss.xml" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">RSS feed</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-start gap-4 border-t border-rule pt-8 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 md:flex-row md:items-center md:justify-between">
      <span class="inline-flex items-center gap-3.5">
        <Mark size={18} />
        <span>Apache 2.0 · github.com/adamant-protocol</span>
      </span>
      <span>No endorsements · No promises · No master</span>
    </div>
  </div>
</footer>
