---
import Mark from './Mark.astro';

const GITHUB = 'https://github.com/adamant-protocol/adamant';
const X = 'https://x.com/AdamantProtocol';
---

<footer class="relative z-[5] mt-[200px] border-t border-rule px-0 py-24 pb-12">
  <div class="wrap">
    <div class="mb-24 grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-20 lg:grid-cols-[2.2fr_1fr_1fr_1fr]">
      <div class="md:col-span-2 lg:col-span-1">
        <p class="max-w-[34ch] font-display text-[22px] leading-[1.4] tracking-[-0.02em] text-ink">
          <span class="font-light text-ink-2">A piece of public infrastructure.</span><br />
          Treated as one.
        </p>

        <!-- Social row -->
        <div class="mt-6 flex items-center gap-4">
          <a
            href={X}
            class="inline-flex items-center justify-center w-9 h-9 rounded-sm border border-rule-2 text-ink-2 transition-colors hover:text-ember hover:border-ember"
            aria-label="Adamant on X"
            rel="noopener"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://github.com/adamant-protocol"
            class="inline-flex items-center justify-center w-9 h-9 rounded-sm border border-rule-2 text-ink-2 transition-colors hover:text-ember hover:border-ember"
            aria-label="Adamant on GitHub"
            rel="noopener"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.73-1.54-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.94 10.94 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.68 5.36-5.24 5.65.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Protocol</h4>
        <ul class="flex flex-col gap-3">
          <li><a href="/about" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">About</a></li>
          <li><a href="/spec" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Whitepaper</a></li>
          <li><a href="/genesis" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Genesis</a></li>
          <li><a href="/wallet" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Wallet</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Code</h4>
        <ul class="flex flex-col gap-3">
          <li><a href={GITHUB} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">GitHub</a></li>
          <li><a href={`${GITHUB}/issues`} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Issues</a></li>
          <li><a href={`${GITHUB}/discussions`} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Discussions</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Community</h4>
        <ul class="flex flex-col gap-3">
          <li><a href={X} class="text-[14.5px] text-ink-2 transition-colors hover:text-ink" rel="noopener">X / Twitter</a></li>
          <li><a href="/updates" class="text-[14.5px] text-ink-2 transition-colors hover:text-ink">Updates</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-start gap-4 border-t border-rule pt-8 font-mono text-[11px] uppercase tracking-[0.12em] text-ink-3 md:flex-row md:items-center md:justify-between">
      <span class="inline-flex flex-wrap items-center gap-x-3 gap-y-1.5">
        <Mark size={28} />
        <a href={`${GITHUB}/blob/main/LICENSE`} class="transition-colors hover:text-ink-2">Apache 2.0</a>
        <span class="text-ink-4">·</span>
        <a href="https://github.com/adamant-protocol" class="transition-colors hover:text-ink-2">github.com/adamant-protocol</a>
      </span>
      <span>Specification draft · Pre-launch · No token sale</span>
    </div>
  </div>
</footer>
