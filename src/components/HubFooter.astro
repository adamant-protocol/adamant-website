---
import { PHASE, SOCIAL_LINKS } from '@/data/chain';
const p = PHASE;
const REPO = 'https://github.com/adamant-protocol/adamant-website';
---

<footer class="foot" role="contentinfo">
  <div class="container">
    <div>
      <a class="brand" href="/" aria-label="Adamant home" style="margin-bottom: 14px;">
        <img class="mark" src="/adm-mark.svg" alt="Adamant" />
        <span class="brand-meta">Protocol</span>
      </a>
      <div class="meta">A Layer 1 blockchain protocol.<br/>No foundation. No premine. No admin keys.</div>
      <div class="meta" style="margin-top:14px;">
        <span class="phase-pill" data-phase={p.key}><span>{p.shortLabel}</span></span>
      </div>
      <div class="foot-socials" aria-label="Social links">
        <a href={SOCIAL_LINKS.github} rel="noopener" target="_blank" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .297C5.373.297 0 5.67 0 12.297c0 5.302 3.438 9.8 8.205 11.385.6.111.82-.26.82-.577 0-.286-.011-1.04-.016-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.418-1.305.762-1.605-2.665-.302-5.467-1.332-5.467-5.93 0-1.31.467-2.382 1.235-3.222-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.5 11.5 0 0 1 3.003-.404c1.018.005 2.045.137 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.654 1.652.243 2.873.12 3.176.77.84 1.232 1.911 1.232 3.222 0 4.61-2.807 5.625-5.479 5.92.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .319.218.694.825.576C20.565 22.092 24 17.594 24 12.297 24 5.67 18.627.297 12 .297z"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a href={SOCIAL_LINKS.x} rel="noopener" target="_blank" aria-label="X">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.451-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/>
          </svg>
          <span>X</span>
        </a>
      </div>
    </div>
    <div>
      <h4>The hub</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/genesis">Genesis</a></li>
        <li><a href="/network">Network</a></li>
        <li><a href="/wallet">Wallet</a></li>
        <li><a href="/operator">Operator</a></li>
        <li><a href="/spec">Spec</a></li>
        <li><a href="/updates">Updates</a></li>
      </ul>
    </div>
    <div>
      <h4>Reference</h4>
      <ul>
        <li><a href={`${REPO}/tree/main/whitepaper`} rel="noopener" target="_blank">Whitepaper · markdown</a></li>
        <li><a href={`${REPO}/tree/main/whitepaper/adamant-whitepaper-complete.md`} rel="noopener" target="_blank">Single-file whitepaper</a></li>
        <li><a href={REPO} rel="noopener" target="_blank">GitHub repository</a></li>
        <li><a href="/llms.txt">llms.txt</a></li>
      </ul>
    </div>
    <div>
      <h4>Channels</h4>
      <ul>
        <li><a href={`${REPO}/commits/main`} rel="noopener" target="_blank">Commit log</a></li>
        <li><a href={`${REPO}/issues`} rel="noopener" target="_blank">Discussion</a></li>
        <li><a href="/updates">Project journal</a></li>
        <li><a href="/sitemap-index.xml">Sitemap</a></li>
      </ul>
    </div>
  </div>
  <div class="container">
    <div class="build">
      <span>Spec v0.1 · pre-launch · Apache 2.0</span>
      <span>Privacy by default. Verifiable by anyone. Governed by no one.</span>
    </div>
  </div>
</footer>
