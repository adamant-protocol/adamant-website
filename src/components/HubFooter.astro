---
import { PHASE, SOCIAL_LINKS } from '@/data/chain';
const p = PHASE;
const REPO = 'https://github.com/adamant-protocol';
---

<footer class="foot" role="contentinfo">
  <div class="container">
    <div>
      <a class="brand" href="/" aria-label="Adamant home" style="margin-bottom: 14px;">
        <img class="mark" src="/adm-mark.svg" alt="Adamant" />
        <span class="brand-meta">Protocol</span>
      </a>
      <div class="meta">A Layer 1 blockchain protocol.<br/>No foundation. No premine. No admin keys.</div>
      <div class="meta" style="margin-top:14px;">
        <span class="phase-pill" data-phase={p.key}><span>{p.shortLabel}</span></span>
      </div>
      <div class="foot-socials" aria-label="Social links">
        <a href={SOCIAL_LINKS.github} rel="noopener" target="_blank" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.27 1.98-.405 3-.405 1.02 0 2.04.135 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.66 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.895-.015 3.285 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          <span>GitHub</span>
        </a>
        <a href={SOCIAL_LINKS.x} rel="noopener" target="_blank" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span>X</span>
        </a>
      </div>
    </div>
    <div>
      <h4>The hub</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/start">Start here</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/genesis">Genesis</a></li>
        <li><a href="/tokenomics">Tokenomics</a></li>
        <li><a href="/spec">Spec</a></li>
        <li><a href="/developers">Developers</a></li>
        <li><a href="/docs">Docs</a></li>
        <li><a href="/roadmap">Roadmap</a></li>
        <li><a href="/updates">Updates</a></li>
      </ul>
    </div>
    <div>
      <h4>Interfaces</h4>
      <ul>
        <li><a href="/network">Explorer</a></li>
        <li><a href="/wallet">Wallet</a></li>
        <li><a href="/operator">Operator</a></li>
        <li><a href="/status">Status</a></li>
        <li><a href="/security">Security</a></li>
        <li><a href="/ecosystem">Ecosystem</a></li>
        <li><a href="/integrations">Integrations</a></li>
        <li><a href="/grants">Grants</a></li>
        <li><a href="/community">Community</a></li>
      </ul>
    </div>
    <div>
      <h4>Reference</h4>
      <ul>
        <li><a href={`https://github.com/adamant-protocol/adamant-spec`} rel="noopener" target="_blank">Whitepaper · markdown</a></li>
        <li><a href={`https://github.com/adamant-protocol/adamant-spec/blob/main/whitepaper/adamant-whitepaper-complete.md`} rel="noopener" target="_blank">Single-file whitepaper</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/glossary">Glossary</a></li>
        <li><a href="/archive">Archive</a></li>
        <li><a href="/press">Press kit</a></li>
        <li><a href="/legal">Legal &amp; privacy</a></li>
        <li><a href="/license">License · Apache 2.0</a></li>
        <li><a href="/llms.txt">llms.txt</a></li>
        <li><a href="/sitemap-index.xml">Sitemap</a></li>
      </ul>
    </div>
  </div>
  <div class="container">
    <div class="build">
      <span id="permanence-line">— spec v0.1 · pre-launch · year 0 of operation</span>
      <span>Privacy by default. Verifiable by anyone. Governed by no one.</span>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    function apply() {
      var p = (window.AdamantPhase && window.AdamantPhase.get()) || { key: 'prelaunch' };
      var el = document.getElementById('permanence-line');
      if (!el) return;
      var spec = 'spec v0.1';
      if (p.key === 'prelaunch') {
        el.textContent = '— ' + spec + ' · pre-launch · year 0 of operation';
      } else if (p.key === 'halted') {
        el.textContent = '— ' + spec + ' · halted at block ' + (p.blockHeight || '—');
      } else if (p.live) {
        var seconds = (p.blockHeight || 0) * 8;
        var year = Math.max(1, Math.floor(seconds / (3600 * 24 * 365)) + 1);
        el.textContent = '— ' + spec + ' · year ' + year + ' of operation · block ' + (p.blockHeight ? p.blockHeight.toLocaleString('en-US') : '—');
      }
    }
    if (window.AdamantPhase) apply();
    window.addEventListener('adamant-phase', apply);
    window.addEventListener('DOMContentLoaded', apply);
  })();
</script>
