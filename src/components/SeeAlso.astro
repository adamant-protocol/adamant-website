---
import { PAGES } from '@/data/chain';

interface Props {
  current?: string;
}
const { current = 'home' } = Astro.props;

const RELATED: Record<string, string[]> = {
  home:       ['start', 'spec', 'developers'],
  start:      ['spec', 'wallet', 'developers'],
  about:      ['spec', 'genesis', 'security'],
  genesis:    ['operator', 'network', 'spec'],
  network:    ['developers', 'wallet', 'status'],
  wallet:     ['network', 'security', 'developers'],
  operator:   ['developers', 'genesis', 'network'],
  spec:       ['developers', 'security', 'genesis'],
  updates:    ['spec', 'network', 'operator'],
  developers: ['network', 'spec', 'security'],
  security:   ['spec', 'status', 'developers'],
  status:     ['network', 'security', 'updates'],
  roadmap:    ['spec', 'developers', 'security'],
  ecosystem:  ['developers', 'wallet', 'network'],
};

const order = RELATED[current] ?? PAGES.filter((p) => p.k !== current).map((p) => p.k);
const items = order
  .map((k) => PAGES.find((p) => p.k === k))
  .filter((p): p is (typeof PAGES)[number] => Boolean(p) && p.k !== current);
---

{items.length > 0 && (
  <section class="see-also-section" data-reveal>
    <div class="container">
      <div class="see-also">
        <span class="label">See also</span>
        {items.map((p) => (
          <a href={p.href}>{p.label} &rarr;</a>
        ))}
      </div>
    </div>
  </section>
)}
