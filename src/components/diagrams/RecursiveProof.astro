---
// Halo 2 recursive verification — proof of proof of proof
---
<figure class="adm-diagram" aria-label="Halo 2 recursive verification">
  <svg viewBox="0 0 800 280" role="img" aria-labelledby="rp-title rp-desc">
    <title id="rp-title">Halo 2 recursive verification</title>
    <desc id="rp-desc">A single recursive proof attests to the validity of all earlier proofs; a phone can verify the chain from one anchor.</desc>

    <!-- many txs at bottom -->
    <g>
      {Array.from({length: 24}).map((_, i) => (
        <rect x={20 + i * 32} y="200" width="22" height="14" fill="none" stroke="currentColor" opacity="0.55"/>
      ))}
      <text x="400" y="240" text-anchor="middle" font-family="var(--mono)" font-size="10" fill="currentColor" opacity="0.6">individual transaction proofs</text>
    </g>

    <!-- intermediate -->
    <g>
      {Array.from({length: 6}).map((_, i) => (
        <rect x={80 + i * 110} y="120" width="64" height="36" fill="none" stroke="currentColor"/>
      ))}
    </g>
    <g stroke="currentColor" fill="none" opacity="0.35">
      {Array.from({length: 24}).map((_, i) => {
        const fromX = 31 + i * 32;
        const toX = 112 + Math.floor(i / 4) * 110;
        return <path d={`M ${fromX} 200 L ${toX} 156`} />;
      })}
    </g>

    <!-- top recursive -->
    <g>
      <rect x="320" y="40" width="160" height="48" fill="var(--ink)"/>
      <text x="400" y="62" text-anchor="middle" font-family="var(--mono)" font-size="10" letter-spacing="0.14em" fill="var(--paper)" opacity="0.7">ANCHOR</text>
      <text x="400" y="80" text-anchor="middle" font-family="var(--serif)" font-size="16" fill="var(--paper)">Recursive proof</text>
    </g>
    <g stroke="currentColor" fill="none" opacity="0.5">
      {[0, 1, 2, 3, 4, 5].map((i) => (
        <path d={`M ${112 + i * 110} 120 L 400 88`} />
      ))}
    </g>

    <!-- phone -->
    <g transform="translate(680,50)">
      <rect x="0" y="0" width="56" height="100" fill="none" stroke="currentColor"/>
      <rect x="6" y="10" width="44" height="68" fill="none" stroke="currentColor" opacity="0.5"/>
      <circle cx="28" cy="88" r="3" fill="none" stroke="currentColor"/>
      <text x="28" y="125" text-anchor="middle" font-family="var(--mono)" font-size="9" letter-spacing="0.10em" fill="currentColor" opacity="0.7">PHONE</text>
      <text x="28" y="140" text-anchor="middle" font-family="var(--mono)" font-size="9" fill="currentColor" opacity="0.55">verifies all</text>
    </g>
    <path d="M 480 64 L 670 90" stroke="currentColor" fill="none" stroke-dasharray="3 3" opacity="0.5"/>
  </svg>
  <figcaption class="adm-diagram-caption">Recursive verification · WP §7.5, §8.5</figcaption>
</figure>

<style>
  .adm-diagram { margin: 24px 0; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); }
  .adm-diagram svg { display: block; width: 100%; height: auto; padding: 18px; box-sizing: border-box; }
  .adm-diagram-caption { border-top: 1px solid var(--rule); padding: 10px 18px; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3); background: var(--paper-2); }
</style>
