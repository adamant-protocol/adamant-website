---
// Halo 2 recursive verification — proof of proof of proof
---
<figure class="adm-diagram" aria-label="Halo 2 recursive verification">
  <svg viewBox="0 0 860 320" preserveAspectRatio="xMidYMid meet" role="img" aria-labelledby="rp-title rp-desc">
    <title id="rp-title">Halo 2 recursive verification</title>
    <desc id="rp-desc">A single recursive proof attests to the validity of all earlier proofs; a phone can verify the chain from one anchor.</desc>
    <style>
      .d-text { font-family: "Newsreader", Georgia, serif; }
      .d-mono { font-family: "JetBrains Mono", "SF Mono", Menlo, monospace; }
      .d-eyebrow { font-size: 11px; letter-spacing: 0.14em; opacity: 0.7; }
      .d-small   { font-size: 10.5px; opacity: 0.6; letter-spacing: 0.06em; }
    </style>

    <!-- many txs at bottom -->
    {Array.from({length: 22}).map((_, i) => (
      <rect x={30 + i * 32} y="232" width="22" height="16" fill="none" stroke="currentColor" opacity="0.55"/>
    ))}
    <text x="380" y="278" text-anchor="middle" class="d-mono d-small" fill="currentColor">individual transaction proofs</text>

    <!-- intermediate -->
    {Array.from({length: 6}).map((_, i) => (
      <rect x={60 + i * 110} y="140" width="70" height="38" fill="none" stroke="currentColor"/>
    ))}
    <g stroke="currentColor" fill="none" opacity="0.3">
      {Array.from({length: 22}).map((_, i) => {
        const fromX = 41 + i * 32;
        const toX = 95 + Math.floor((i * 6) / 22) * 110;
        return <path d={`M ${fromX} 232 L ${toX} 178`} />;
      })}
    </g>

    <!-- top recursive -->
    <rect x="320" y="50" width="200" height="56" fill="currentColor"/>
    <text x="420" y="74"  text-anchor="middle" class="d-mono d-eyebrow" fill="var(--paper)">ANCHOR</text>
    <text x="420" y="94"  text-anchor="middle" class="d-text" font-size="17" fill="var(--paper)">Recursive proof</text>

    <g stroke="currentColor" fill="none" opacity="0.5">
      {[0, 1, 2, 3, 4, 5].map((i) => (
        <path d={`M ${95 + i * 110} 140 L 420 106`} />
      ))}
    </g>

    <!-- phone -->
    <g transform="translate(720,52)">
      <rect x="0" y="0" width="64" height="110" fill="none" stroke="currentColor"/>
      <rect x="7" y="11" width="50" height="76" fill="none" stroke="currentColor" opacity="0.5"/>
      <circle cx="32" cy="98" r="3.5" fill="none" stroke="currentColor"/>
      <text x="32" y="134" text-anchor="middle" class="d-mono d-eyebrow" fill="currentColor">PHONE</text>
      <text x="32" y="150" text-anchor="middle" class="d-mono d-small" fill="currentColor">verifies all</text>
    </g>
    <path d="M 520 76 L 712 100" stroke="currentColor" fill="none" stroke-dasharray="3 3" opacity="0.5"/>
  </svg>
  <figcaption class="adm-diagram-caption">Recursive verification · WP §7.5, §8.5</figcaption>
</figure>

<style>
  .adm-diagram { margin: 24px 0; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); }
  .adm-diagram svg { display: block; width: 100%; height: auto; padding: 0; box-sizing: border-box; }
  .adm-diagram > svg { padding: 24px; }
  .adm-diagram-caption { border-top: 1px solid var(--rule); padding: 10px 18px; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3); background: var(--paper-2); }
</style>
