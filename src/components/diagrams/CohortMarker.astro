---
// Cohort marker (immovable) vs Genesis NFT (tradeable)
---
<figure class="adm-diagram" aria-label="Cohort marker versus Genesis NFT">
  <svg viewBox="0 0 800 240" role="img" aria-labelledby="cm-title cm-desc">
    <title id="cm-title">Cohort marker versus Genesis NFT</title>
    <desc id="cm-desc">The cohort marker is permanently bound to the original validator address. The Genesis NFT is freely tradeable. They are separate artefacts.</desc>

    <!-- left: marker (immovable) -->
    <g>
      <rect x="20" y="40" width="360" height="180" fill="none" stroke="currentColor" stroke-width="2"/>
      <text x="40" y="76" font-family="var(--mono)" font-size="11" letter-spacing="0.14em" fill="currentColor" opacity="0.6">IMMOVABLE</text>
      <text x="40" y="108" font-family="var(--serif)" font-size="24" fill="currentColor">Cohort marker</text>
      <text x="40" y="138" font-family="var(--serif)" font-size="14" fill="currentColor" opacity="0.7">attached to the original address</text>
      <text x="40" y="158" font-family="var(--serif)" font-size="14" fill="currentColor" opacity="0.7">for the lifetime of the chain</text>

      <!-- lock motif -->
      <g transform="translate(290,80) scale(2)">
        <rect x="0" y="10" width="30" height="22" fill="none" stroke="currentColor"/>
        <path d="M 6 10 V 5 a 9 9 0 0 1 18 0 V 10" fill="none" stroke="currentColor"/>
        <circle cx="15" cy="21" r="2" fill="currentColor"/>
      </g>
    </g>

    <!-- right: NFT (tradeable) -->
    <g>
      <rect x="420" y="40" width="360" height="180" fill="var(--paper-3)" stroke="currentColor"/>
      <text x="440" y="76" font-family="var(--mono)" font-size="11" letter-spacing="0.14em" fill="currentColor" opacity="0.6">TRADEABLE</text>
      <text x="440" y="108" font-family="var(--serif)" font-size="24" fill="currentColor">Genesis NFT</text>
      <text x="440" y="138" font-family="var(--serif)" font-size="14" fill="currentColor" opacity="0.7">no protocol function</text>
      <text x="440" y="158" font-family="var(--serif)" font-size="14" fill="currentColor" opacity="0.7">cultural artefact · transferable</text>

      <!-- exchange motif -->
      <g transform="translate(690,90)" stroke="currentColor" fill="none">
        <path d="M 0 10 L 40 10 L 32 2 M 40 10 L 32 18"/>
        <path d="M 40 30 L 0 30 L 8 22 M 0 30 L 8 38"/>
      </g>
    </g>
  </svg>
  <figcaption class="adm-diagram-caption">Two artefacts, one cohort · WP §8.1.9</figcaption>
</figure>

<style>
  .adm-diagram { margin: 24px 0; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); }
  .adm-diagram svg { display: block; width: 100%; height: auto; padding: 18px; box-sizing: border-box; }
  .adm-diagram-caption { border-top: 1px solid var(--rule); padding: 10px 18px; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3); background: var(--paper-2); }
</style>
