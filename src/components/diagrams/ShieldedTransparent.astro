---
// Shielded vs transparent state: split rectangle showing what each side reveals.
---
<figure class="adm-diagram" aria-label="Shielded vs transparent state">
  <svg viewBox="0 0 860 320" preserveAspectRatio="xMidYMid meet" role="img" aria-labelledby="st-title st-desc">
    <title id="st-title">Shielded vs transparent state</title>
    <desc id="st-desc">A side-by-side comparison of what observers can see for shielded versus transparent objects on Adamant.</desc>
    <style>
      .d-text { font-family: "Instrument Serif", Georgia, serif; }
      .d-mono { font-family: "Geist Mono", "SF Mono", Menlo, monospace; }
      .d-eyebrow { font-size: 11px; letter-spacing: 0.14em; opacity: 0.6; }
    </style>

    <!-- shielded -->
    <g>
      <rect x="20" y="20" width="400" height="280" fill="var(--ink)"/>
      <text x="40" y="56"  class="d-mono d-eyebrow" fill="var(--paper)">DEFAULT</text>
      <text x="40" y="92"  class="d-text" font-size="30" fill="var(--paper)">Shielded</text>
      <line x1="40" y1="108" x2="400" y2="108" stroke="var(--paper)" opacity="0.3"/>

      <g class="d-mono" fill="var(--paper)" font-size="13" letter-spacing="0.04em">
        <text x="40" y="140">Existence</text>     <text x="380" y="140" text-anchor="end" opacity="0.95">visible</text>
        <text x="40" y="166">Validity proof</text> <text x="380" y="166" text-anchor="end" opacity="0.95">visible</text>
        <text x="40" y="192">Fee</text>            <text x="380" y="192" text-anchor="end" opacity="0.95">visible</text>
        <text x="40" y="218">Sender</text>         <text x="380" y="218" text-anchor="end" opacity="0.55">encrypted</text>
        <text x="40" y="244">Recipient</text>      <text x="380" y="244" text-anchor="end" opacity="0.55">encrypted</text>
        <text x="40" y="270">Amount</text>         <text x="380" y="270" text-anchor="end" opacity="0.55">encrypted</text>
      </g>
    </g>

    <!-- transparent -->
    <g>
      <rect x="440" y="20" width="400" height="280" fill="none" stroke="currentColor"/>
      <text x="460" y="56"  class="d-mono d-eyebrow" fill="currentColor">OPT-IN</text>
      <text x="460" y="92"  class="d-text" font-size="30" fill="currentColor">Transparent</text>
      <line x1="460" y1="108" x2="820" y2="108" stroke="currentColor" opacity="0.2"/>

      <g class="d-mono" fill="currentColor" font-size="13" letter-spacing="0.04em">
        <text x="460" y="140">Existence</text>     <text x="820" y="140" text-anchor="end">visible</text>
        <text x="460" y="166">Validity proof</text> <text x="820" y="166" text-anchor="end">n/a</text>
        <text x="460" y="192">Fee</text>            <text x="820" y="192" text-anchor="end">visible</text>
        <text x="460" y="218">Sender</text>         <text x="820" y="218" text-anchor="end">visible</text>
        <text x="460" y="244">Recipient</text>      <text x="820" y="244" text-anchor="end">visible</text>
        <text x="460" y="270">Amount</text>         <text x="820" y="270" text-anchor="end">visible</text>
      </g>
    </g>
  </svg>
  <figcaption class="adm-diagram-caption">Privacy is structural · WP §7.1</figcaption>
</figure>

<style>
  .adm-diagram { margin: 24px 0; border: 1px solid var(--rule); background: var(--paper); color: var(--ink); }
  .adm-diagram svg { display: block; width: 100%; height: auto; padding: 0; box-sizing: border-box; }
  .adm-diagram > svg { padding: 24px; }
  .adm-diagram-caption { border-top: 1px solid var(--rule); padding: 10px 18px; font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3); background: var(--paper-2); }
</style>
