---
// Per-primitive audit progress, with visible bars.
// pct values are public-status estimates; replace as audits complete.
const ITEMS = [
  { code: 'C.01', name: 'Halo 2',                use: 'Recursive zk-SNARK',          pct: 50, label: 'reference upstream audited; Adamant gadgets pre-audit' },
  { code: 'C.02', name: 'ML-DSA (FIPS 204)',     use: 'Post-quantum signatures',     pct: 90, label: 'NIST-final standard; Adamant hybrid integration pre-audit' },
  { code: 'C.03', name: 'Ed25519',               use: 'Classical signatures',        pct: 95, label: 'industry standard' },
  { code: 'C.04', name: 'ML-KEM-768 (FIPS 203)', use: 'Post-quantum KEM',            pct: 90, label: 'NIST-final standard' },
  { code: 'C.05', name: 'Wesolowski VDF',        use: 'Mempool time-lock',           pct: 30, label: 'parameter review pending; group-of-unknown-order setup' },
  { code: 'C.06', name: 'Threshold BLS',         use: 'Mempool threshold encryption',pct: 25, label: 'DKG construction pre-audit' },
  { code: 'C.07', name: 'BLAKE3',                use: 'Auxiliary hashing',           pct: 95, label: 'industry standard' },
  { code: 'C.08', name: 'Poseidon',              use: 'zk-friendly hashing',         pct: 60, label: 'parameters fixed; circuit-level review in flight' },
];
---
<div class="audit-grid">
  {ITEMS.map((it) => (
    <article class="audit-card">
      <div class="audit-head">
        <span class="mono small" style="color: var(--ink-3); letter-spacing: 0.14em;">{it.code}</span>
        <span class="serif" style="font-size: 18px; line-height: 1.1;">{it.name}</span>
        <span class="mono small" style="color: var(--ink-3);">{it.use}</span>
      </div>
      <div class="audit-bar" aria-label={`${it.name} audit progress: ${it.pct}%`}>
        <div class="audit-bar-fill" style={`width: ${it.pct}%`}></div>
        <span class="audit-bar-tick mono">{it.pct} %</span>
      </div>
      <p class="audit-label">{it.label}</p>
    </article>
  ))}
</div>

<style>
  .audit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }
  .audit-card {
    padding: 18px;
    border-left: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .audit-card:nth-child(odd) { border-left: 0; }
  .audit-card:nth-last-child(-n+2) { border-bottom: 0; }
  .audit-head { display: flex; flex-direction: column; gap: 4px; }
  .audit-bar { position: relative; height: 16px; border: 1px solid var(--ink); background: var(--paper-2); }
  .audit-bar-fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--ink); }
  .audit-bar-tick { position: absolute; right: 6px; top: 50%; transform: translateY(-50%); font-size: 10px; letter-spacing: 0.06em; color: var(--paper); mix-blend-mode: difference; }
  .audit-label { margin: 0; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.04em; }
  @media (max-width: 760px) {
    .audit-grid { grid-template-columns: 1fr; }
    .audit-card { border-left: 0; }
    .audit-card:nth-child(odd) { border-left: 0; }
    .audit-card:nth-last-child(-n+2) { border-bottom: 1px solid var(--rule); }
    .audit-card:last-child { border-bottom: 0; }
  }
</style>
