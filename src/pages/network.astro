---
import HubLayout from '@/layouts/HubLayout.astro';
---

<HubLayout active="network" title="Adamant — Network" description="Operational view of the live chain. Validator set, recent blocks, mempool, throughput.">

  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ Network · operational view</div>
        <h1 class="title">Operational view<br/><em style="font-style:italic; color:var(--ink-2);">of the live chain.</em></h1>
      </div>
      <div>
        <p class="lede">
          What is happening on the chain right now. Validator set, recent blocks, mempool, throughput. This page is intended for monitoring; the data on it is the canonical record. During the specification phase, all live values are placeholders.
        </p>
      </div>
    </div>
  </section>

  <!-- HEALTH SUMMARY -->
  <section class="section" style="padding: 32px 0;">
    <div class="container">
      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="net-health">
        {[
          { label: 'Throughput · TPS', target: '≥ 50 000 floor' },
          { label: 'Average finality · ms', target: 'sub-second target' },
          { label: 'Active validators', target: 'floor 7 · ceiling 75' },
        ].map((c) => (
          <div style="border: 1px solid var(--rule); padding: 16px; background: var(--paper);">
            <span class="label">{c.label}</span>
            <span class="v" data-spec="true" style="font-family: var(--mono); font-size: 28px; line-height: 1; margin-top: 6px; display:block; color: var(--ink-2);">specification</span>
            <div style="height: 80px; margin-top: 14px; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-style: italic; color: var(--ink-3); font-size: 14px;">no live chain</div>
            <span class="mono small" style="color: var(--ink-3); margin-top: 8px; display: block;">{c.target}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALIDATORS + RECENT BLOCKS + MEMPOOL -->
  <section style="padding: 0 0 32px;">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px;" class="net-grid">

        <!-- LEFT: validators -->
        <div>
          <div style="border: 1px solid var(--rule); background: var(--paper);">
            <div style="display:flex; justify-content:space-between; align-items:center; padding: 12px 16px; border-bottom: 1px solid var(--rule);">
              <span class="label">Active validator set · 0 of 75</span>
              <span class="mono small" style="color: var(--ink-3);">specification phase</span>
            </div>
            <div class="scroll-x">
              <table class="ledger">
                <thead>
                  <tr>
                    <th style="width: 56px;">#</th>
                    <th>Address</th>
                    <th class="r">Uptime · 7d</th>
                    <th class="r">Latency</th>
                    <th class="r">Bonded</th>
                    <th class="r">Rewards · ep</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td colspan="7" style="color: var(--ink-3); padding: 32px 16px; font-family: var(--serif); font-style: italic;">No validators yet — set begins forming at testnet activation.</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div style="border: 1px solid var(--rule); background: var(--paper); margin-top: 24px;">
            <div style="display:flex; justify-content:space-between; align-items:center; padding: 12px 16px; border-bottom: 1px solid var(--rule);">
              <span class="label">Standby queue · 0</span>
              <span class="mono small" style="color: var(--ink-3);">in registration order</span>
            </div>
            <div style="padding: 24px 16px; color: var(--ink-3); font-family: var(--serif); font-style: italic;">Standby queue is empty.</div>
          </div>
        </div>

        <!-- RIGHT: recent blocks + mempool + composition -->
        <div style="display:flex; flex-direction: column; gap: 24px;">
          <div style="border: 1px solid var(--rule); background: var(--paper);">
            <div style="display:flex; justify-content:space-between; align-items:center; padding: 12px 16px; border-bottom: 1px solid var(--rule);">
              <span class="label">Recent blocks</span>
              <span class="mono small" style="color: var(--ink-3);">last 8</span>
            </div>
            <div style="padding: 32px 16px; color: var(--ink-3); font-family: var(--serif); font-style: italic;">No blocks yet — chain is in specification phase.</div>
          </div>

          <div style="border: 1px solid var(--rule); background: var(--paper);">
            <div style="display:flex; justify-content:space-between; align-items:center; padding: 12px 16px; border-bottom: 1px solid var(--rule);">
              <span class="label">Mempool</span>
              <span class="mono small" style="color: var(--ink-3);">two-regime · threshold + VDF time-lock</span>
            </div>
            <div style="display:flex; justify-content: space-between; padding: 18px 16px;">
              <div>
                <div class="label">Pending</div>
                <div class="mono" style="font-size: 22px; font-variant-numeric: tabular-nums; color: var(--ink-2);" data-spec="true">specification</div>
              </div>
              <div>
                <div class="label">Encryption</div>
                <div class="mono" style="font-size: 13px; line-height: 1.2; max-width: 22ch; text-align: right; margin-top: 8px;">Threshold (N≥15)<br/>Time-lock VDF (N&lt;15)</div>
              </div>
            </div>
          </div>

          <div style="border: 1px solid var(--rule); background: var(--paper);">
            <div style="display:flex; justify-content:space-between; align-items:center; padding: 12px 16px; border-bottom: 1px solid var(--rule);">
              <span class="label">Active set composition</span>
              <span class="mono small" style="color: var(--ink-3);">at activation</span>
            </div>
            <div style="padding: 16px;">
              <div style="display:flex; height: 38px; border: 1px solid var(--rule);">
                <div style="flex: 75; background: var(--paper-3);"></div>
              </div>
              <div style="display:flex; justify-content: space-between; margin-top: 10px;" class="mono small">
                <span><span style="display:inline-block; width:8px; height:8px; background: var(--ink); margin-right:6px;"></span>Cohort</span>
                <span><span style="display:inline-block; width:8px; height:8px; background: var(--ink-3); margin-right:6px;"></span>Post-cohort</span>
                <span><span style="display:inline-block; width:8px; height:8px; background: var(--paper-3); border:1px solid var(--rule); margin-right:6px;"></span>Open</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</HubLayout>

<style>
@media (max-width: 980px) {
  .net-grid { grid-template-columns: 1fr !important; }
  .net-health { grid-template-columns: 1fr !important; }
}
</style>
