---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Starfield from '@/components/Starfield.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('updates', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' }).toUpperCase();
---

<BaseLayout
  active="updates"
  title="Adamant — Updates"
  description="Project updates, design notes, and progress reports from the Adamant protocol."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-[120px] pb-20">
    <Starfield />
    <div class="wrap relative z-[3]">
      <div class="grid items-end gap-24 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <span class="eyebrow"><span class="dot"></span>Project journal</span>
          <h1 class="mt-9 max-w-[14ch] font-display font-medium leading-none tracking-[-0.035em]" style="font-size:clamp(40px,5.5vw,84px)">
            <span class="block font-light text-ink-2">Updates</span>
            <span class="font-semibold text-ember">from the build.</span>
          </h1>
          <p class="mt-9 max-w-[46ch] text-[16.5px] leading-[1.7] text-ink-2">
            Where the project is, what's been decided, and what's still being worked through. Posted as commits land — no schedule, no marketing.
          </p>
        </div>
        <div class="flex flex-col gap-5 pb-2">
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Posts</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em]">{posts.length}</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Feed</span>
            <a href="/rss.xml" class="font-mono text-[13px] text-ink tracking-[0.05em] hover:text-ember transition-colors">RSS</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- List -->
  <section class="border-t border-rule">
    <div class="wrap">
      {posts.length === 0 ? (
        <div class="py-32 text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">No posts yet</p>
        </div>
      ) : (
        <ol class="flex flex-col">
          {posts.map((post) => (
            <li>
              <a
                href={`/updates/${post.slug}`}
                class="group grid items-center gap-8 border-b border-rule py-10 transition-colors hover:bg-bg-2 lg:grid-cols-[160px_1fr_auto] lg:px-6 lg:-mx-6"
              >
                <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3 group-hover:text-ember transition-colors">{fmtDate(post.data.date)}</span>
                <div>
                  <h2 class="mb-2 font-display text-[24px] font-medium leading-[1.2] tracking-[-0.02em] group-hover:text-ember transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="max-w-[60ch] text-[14.5px] leading-[1.6] text-ink-2">{post.data.description}</p>
                </div>
                <span class="hidden lg:inline-block h-px w-10 relative bg-ink-3 group-hover:bg-ember transition-colors after:absolute after:right-0 after:-top-[3px] after:size-[7px] after:border-r after:border-b after:border-current after:rotate-[-45deg]"></span>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 text-center">
    <div class="wrap">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-ink-3">Want every update as it lands?</p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a href="/rss.xml" class="btn-link">RSS feed <span class="arrow"></span></a>
        <a href="https://github.com/adamant-protocol/adamant" class="btn-link">Watch the repo <span class="arrow"></span></a>
      </div>
    </div>
  </section>
</BaseLayout>
