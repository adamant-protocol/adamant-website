        <span class="block font-light text-ink-2">Trust the protocol.</span>
        Not the people <span class="font-semibold text-ember">who built it.</span>
      </h2>
      <div class="mt-12 font-mono text-[11px] md:text-[13px] tracking-[0.24em] uppercase text-ink-3">
        No foundation · No admin keys · No upgrade authority
      </div>
    </div>
  </section>

  <style is:global>
    /* ───────── DAG consensus animation ───────── */
    @keyframes dag-vertex-pulse {
      0%, 100% { opacity: 0.25; transform: scale(0.85); }
      8%, 50% { opacity: 1; transform: scale(1.15); }
      80% { opacity: 0.55; transform: scale(1); }
    }
    .dag-vertex {
      transform-origin: center;
      transform-box: fill-box;
      animation: dag-vertex-pulse 4s ease-in-out infinite;
    }
    @keyframes dag-line-draw {
      0%, 100% { stroke-dashoffset: 60; opacity: 0.1; }
      15%, 60% { stroke-dashoffset: 0; opacity: 0.55; }
      85% { stroke-dashoffset: 0; opacity: 0.2; }
    }
    .dag-line {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: dag-line-draw 4s ease-in-out infinite;
    }

    /* ───────── Encrypted mempool animation ───────── */
    @keyframes mempool-tx-travel {
      0% { transform: translateX(40px); }
      18% { transform: translateX(40px); }
      28%, 50% { transform: translateX(120px); }
      60%, 78% { transform: translateX(200px); }
      88%, 100% { transform: translateX(280px); }
    }
    .mempool-tx { animation: mempool-tx-travel 6s ease-in-out infinite; }
    @keyframes mempool-pill-encrypt {
      0%, 17% { fill: #ff7d4d; }
      28%, 78% { fill: #2e3140; }
      88%, 100% { fill: #ff7d4d; }
    }
    .mempool-pill { animation: mempool-pill-encrypt 6s ease-in-out infinite; }
    @keyframes mempool-lock-show {
      0%, 22% { opacity: 0; }
      28%, 75% { opacity: 1; }
      82%, 100% { opacity: 0; }
    }
    .mempool-lock { animation: mempool-lock-show 6s ease-in-out infinite; }
    @keyframes mempool-keypers-show {
      0%, 55% { opacity: 0; transform: translateY(4px); }
      62%, 78% { opacity: 1; transform: translateY(0); }
      85%, 100% { opacity: 0; }
    }
    .mempool-keypers {
      animation: mempool-keypers-show 6s ease-in-out infinite;
      transform-origin: center;
    }

    /* ───────── Recursive proof animation ───────── */
    @keyframes proof-chain-pulse {
      0%, 30% { opacity: 0.4; }
      40%, 60% { opacity: 1; }
      70%, 100% { opacity: 0.4; }
    }
    .proof-chain { animation: proof-chain-pulse 5s ease-in-out infinite; }
    @keyframes proof-spinner-spin {
      0%, 60% { transform: rotate(0deg); opacity: 1; }
      90%, 100% { opacity: 0; }
    }
    .proof-spinner {
      animation: proof-spinner-spin 5s linear infinite;
      transform-origin: 260px 71px;
      transform-box: view-box;
    }
    @keyframes proof-spinner-rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(720deg); }
    }
    .proof-spinner > circle {
      animation: proof-spinner-rotate 5s linear infinite;
      transform-origin: 260px 71px;
      transform-box: view-box;
    }
    @keyframes proof-check-show {
      0%, 65% { opacity: 0; transform: scale(0.5); }
      75%, 95% { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(1); }
    }
    .proof-check {
      transform-origin: 260px 71px;
      transform-box: fill-box;
      animation: proof-check-show 5s ease-out infinite;
    }

    /* ───────── Constitutional immutability animation ───────── */
    @keyframes immut-validator-pulse {
      0%, 100% { opacity: 0.4; transform: scale(0.9); }
      50% { opacity: 1; transform: scale(1.15); }
    }
    .immut-validator {
      transform-origin: center;
      transform-box: fill-box;
      animation: immut-validator-pulse 3.6s ease-in-out infinite;
    }
    @keyframes immut-radiate-pulse {
      0%, 100% { opacity: 0.1; transform: scale(0.96); }
      50% { opacity: 0.25; transform: scale(1.04); }
    }
    .immut-radiate {
      transform-origin: 160px 90px;
      transform-box: view-box;
      animation: immut-radiate-pulse 4s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
      .dag-vertex, .dag-line, .mempool-tx, .mempool-pill, .mempool-lock,
      .mempool-keypers, .proof-chain, .proof-spinner, .proof-spinner > circle,
      .proof-check, .immut-validator, .immut-radiate {
        animation: none !important;
      }
      .mempool-tx { transform: translateX(40px); }
      .dag-vertex { opacity: 1; transform: scale(1); }
      .dag-line { stroke-dashoffset: 0; opacity: 0.4; }
      .proof-check { opacity: 1; }
      .proof-spinner { opacity: 0; }
      .mempool-lock { opacity: 1; }
      .immut-validator { opacity: 1; }
    }
  </style>
