---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout active="home" ogImage="/home-og.png">
  <!-- ───────── HERO ───────── -->
  <section class="relative overflow-hidden pt-10 md:pt-16 pb-12 md:pb-16">
    <!-- Full-bleed hero image with the monolith centerpiece visible -->
    <div class="pointer-events-none absolute inset-0 z-[1]" aria-hidden="true">
      <img
        src="/hero-2.jpg"
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-center opacity-[0.55] md:opacity-[0.7]"
      />
      <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.55) 70%, #000 100%)"></div>
      <div class="absolute inset-0" style="background:linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.45) 38%, transparent 60%, rgba(0,0,0,0.55) 100%)"></div>
      <div class="absolute inset-0" style="background:radial-gradient(ellipse 50% 45% at 50% 45%, rgba(255,125,77,0.10), transparent 65%)"></div>
    </div>

    <div class="wrap relative z-[3]">
      <div class="grid items-center gap-10 md:gap-14 lg:grid-cols-[1.4fr_1fr]">
        <div data-reveal>
          <span class="eyebrow">
            <span class="dot"></span>
            Layer 1 · Specification draft v0.1
          </span>
          <h1 class="mt-6 max-w-[14ch] font-display font-medium leading-[0.98] tracking-[-0.035em]" style="font-size:clamp(38px,5.4vw,76px)">
            <span class="block font-light text-ink-2">A Layer 1 with</span>
            <span class="block font-semibold">no foundation,</span>
            <span class="block font-bold text-ember">no upgrade authority.</span>
          </h1>
          <p class="mt-7 max-w-[44ch] text-[16px] leading-[1.7] text-ink-2">
            Privacy by default, sub-second finality, and credibly neutral governance enforced at genesis.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/about" class="btn-link solid">Read the introduction <span class="arrow"></span></a>
            <a href="/spec" class="btn-link">Read the specification <span class="arrow"></span></a>
          </div>
        </div>

        <div class="glass rounded-sm p-5 md:p-6 flex flex-col gap-3.5" data-reveal style="transition-delay:140ms">
          <div class="mb-0.5 flex items-center justify-between font-mono text-[10px] uppercase tracking-[0.22em] text-ink-3">
            <span>Targets · v0.1 spec</span>
            <span class="text-ember">DRAFT</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-3">
            <span class="font-mono text-[10.5px] uppercase tracking-[0.2em] text-ink-3">Throughput</span>
            <span class="font-display text-[22px] md:text-[24px] font-medium leading-none tracking-[-0.03em]">200,000<small class="ml-1.5 font-mono text-[9.5px] font-normal tracking-[0.18em] text-ink-3">TPS</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-3">
            <span class="font-mono text-[10.5px] uppercase tracking-[0.2em] text-ink-3">Finality</span>
            <span class="font-display text-[22px] md:text-[24px] font-medium leading-none tracking-[-0.03em]">≈500<small class="ml-1.5 font-mono text-[9.5px] font-normal tracking-[0.18em] text-ink-3">MS</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-3">
            <span class="font-mono text-[10.5px] uppercase tracking-[0.2em] text-ink-3">Fee · transparent</span>
            <span class="font-display text-[22px] md:text-[24px] font-medium leading-none tracking-[-0.03em]">$0.0001<small class="ml-1.5 font-mono text-[9.5px] font-normal tracking-[0.18em] text-ink-3">USD</small></span>
          </div>
          <div class="flex items-baseline justify-between">
            <span class="font-mono text-[10.5px] uppercase tracking-[0.2em] text-ink-3">Default state</span>
            <span class="font-display text-[22px] md:text-[24px] font-medium leading-none tracking-[-0.03em] text-ember">Shielded</span>
          </div>
        </div>
      </div>

      <div class="mt-12 md:mt-16 pt-6 flex items-center justify-between border-t border-rule">
        <span class="font-mono text-[10.5px] tracking-[0.2em] text-ink-3">PRE-LAUNCH · NO TOKEN SALE · NO PRIVATE ALLOCATIONS</span>
        <span class="font-mono text-[10.5px] uppercase tracking-[0.2em] text-ink-2 hidden md:flex items-center gap-3">
          Continue
          <span class="inline-block h-px w-5 relative bg-ink-2 after:absolute after:right-0 after:-top-[3px] after:size-[6px] after:border-r after:border-b after:border-ink-2 after:rotate-[-45deg]"></span>
        </span>
      </div>
    </div>
  </section>

  <!-- ───────── §01 / THE GAP ───────── -->
  <section class="border-t border-rule">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">§01 / THE GAP</span>
          <h2><span class="light">Each property is demonstrated in production.</span>No chain combines more than three.</h2>
        </div>
        <p class="desc">
          Seven properties characterise a usable chain in 2026. Each is, in isolation, well understood and demonstrated in production. <strong class="text-ink">No single chain in the present landscape combines more than three of them.</strong>
        </p>
      </div>

      <!-- Seven property cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-rule-2 border border-rule-2">
        {[
          {
            n: '01',
            prop: '200k+ TPS · sub-second finality',
            chain: 'Sui (Mysticeti)',
            year: '2024',
            lacks: 'No default privacy. Foundation-controlled.',
          },
          {
            n: '02',
            prop: 'Programmable privacy',
            chain: 'Aztec',
            year: '2025',
            lacks: 'L2 only. Multi-second proving. Not a sovereign chain.',
          },
          {
            n: '03',
            prop: 'Encrypted mempool · in production',
            chain: 'Shutter / Gnosis',
            year: '2024',
            lacks: '~3 minute inclusion latency. No programmable privacy.',
          },
          {
            n: '04',
            prop: 'Phone-verifiable chain',
            chain: 'Mina',
            year: '2021',
            lacks: 'Low throughput. No default privacy.',
          },
          {
            n: '05',
            prop: 'Native account abstraction',
            chain: 'zkSync · StarkNet · Aptos',
            year: '2022–24',
            lacks: 'Each on a different chain, with different trade-offs.',
          },
          {
            n: '06',
            prop: 'Post-quantum signatures',
            chain: 'NIST standardisation',
            year: '2024',
            lacks: 'No major chain has launched with these by default.',
          },
        ].map((p) => (
          <article class="bg-bg-2/70 backdrop-blur-sm p-6 md:p-7 flex flex-col gap-3 min-h-[210px] card-hover" data-reveal>
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-3">PROPERTY {p.n}</span>
            <h3 class="font-display text-[17px] md:text-[18.5px] font-medium leading-[1.25] tracking-[-0.018em] text-ink">{p.prop}</h3>
            <div class="mt-1 flex items-baseline gap-2 font-mono text-[11px] tracking-[0.1em]">
              <span class="text-ember">{p.chain}</span>
              <span class="text-ink-4">·</span>
              <span class="text-ink-3">{p.year}</span>
            </div>
            <p class="mt-auto pt-3 border-t border-rule text-[12.5px] leading-[1.55] text-ink-3 italic">but lacks: {p.lacks}</p>
          </article>
        ))}

        <!-- Property 07: spans full width -->
        <article class="bg-bg-2/70 backdrop-blur-sm p-6 md:p-9 lg:p-10 flex flex-col md:flex-row md:items-center gap-5 md:gap-12 lg:col-span-3 card-hover relative overflow-hidden" data-reveal>
          <div class="pointer-events-none absolute inset-0 opacity-30" style="background:linear-gradient(90deg, transparent 0%, rgba(255,125,77,0.05) 100%)"></div>
          <div class="relative md:flex-1">
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-ink-3">PROPERTY 07 · THE ANCHOR</span>
            <h3 class="mt-3 font-display text-[20px] md:text-[24px] font-medium leading-[1.25] tracking-[-0.018em] text-ink max-w-[24ch]">Credibly neutral governance</h3>
          </div>
          <div class="relative md:flex-shrink-0 flex items-baseline gap-2 font-mono text-[12px] tracking-[0.1em]">
            <span class="text-ember">Bitcoin</span>
            <span class="text-ink-4">·</span>
            <span class="text-ember">Monero</span>
            <span class="text-ink-4">·</span>
            <span class="text-ink-3">2009 · 2014</span>
          </div>
          <p class="relative md:max-w-[36ch] text-[13px] leading-[1.55] text-ink-3 italic md:border-l border-rule md:pl-8 md:py-2">but lacks: No programmability. No high throughput.</p>
        </article>
      </div>

      <!-- Adamant card: full width, all seven -->
      <div class="mt-px glass-ember p-8 md:p-12 lg:p-14 relative overflow-hidden card-hover" data-reveal>
        <div class="pointer-events-none absolute inset-0 opacity-60" style="background:radial-gradient(ellipse 80% 80% at 50% 50%, rgba(255,125,77,0.10), transparent 65%)"></div>
        <div class="relative grid items-start gap-8 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-ember">ADAMANT · ALL SEVEN</span>
            <h3 class="mt-4 font-display font-medium leading-[1.05] tracking-[-0.03em]" style="font-size:clamp(28px,3.4vw,48px)">
              <span class="block font-light text-ink-2">Seven properties,</span>
              <span class="font-semibold text-ember">in a single architecture.</span>
            </h3>
            <p class="mt-6 max-w-[44ch] text-[15px] leading-[1.7] text-ink-2">
              The protocol's contribution is not the invention of new cryptographic primitives — those are taken from peer-reviewed literature unchanged — but the systems-level synthesis of these properties into a single coherent architecture, with credible neutrality enforced at genesis.
            </p>
          </div>

          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 font-mono text-[12.5px] tracking-[0.04em]">
            {[
              '200k+ TPS · sub-second finality',
              'Programmable privacy by default',
              'Threshold-encrypted mempool',
              'Phone-verifiable chain',
              'Native account abstraction',
              'Post-quantum signatures',
              'Credibly neutral governance',
            ].map((p) => (
              <li class="flex items-baseline gap-3 text-ink">
                <span class="text-ember font-bold">✓</span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────── §02 / HOW IT WORKS ───────── -->
  <section class="border-t border-rule">
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">§02 / MECHANISMS</span>
          <h2><span class="light">Five mechanisms,</span>each addressing one or more properties.</h2>
        </div>
        <p class="desc">
          Each mechanism resolves one or more of the seven properties no chain has delivered in combination. None is invented here. The protocol's contribution is the synthesis.
        </p>
      </div>

      <!-- ────── MECHANISM 01: DAG CONSENSUS ────── -->
      <div class="mechanism border-y border-rule-2 grid lg:grid-cols-2" data-reveal>
        <div class="bg-bg-2/60 backdrop-blur-sm p-8 md:p-12 lg:p-16 flex flex-col justify-center min-h-[420px]">
          <div class="mb-8 flex items-baseline justify-between gap-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-ember">MECHANISM 01 · CONSENSUS</span>
            <span class="font-mono text-[10px] tracking-[0.18em] text-ink-4">WP §8.3</span>
          </div>

          <!-- Parameter strip -->
          <div class="mb-6 grid grid-cols-2 sm:grid-cols-4 gap-x-4 gap-y-3 font-mono text-[10px] tracking-[0.06em]">
            <div class="flex flex-col gap-0.5"><span class="text-ink-4 uppercase tracking-[0.18em] text-[9px]">N</span><span class="text-ink"><span class="text-ember">200</span> node runners</span></div>
            <div class="flex flex-col gap-0.5"><span class="text-ink-4 uppercase tracking-[0.18em] text-[9px]">Δ round</span><span class="text-ink"><span class="text-ember">250</span> ms</span></div>
            <div class="flex flex-col gap-0.5"><span class="text-ink-4 uppercase tracking-[0.18em] text-[9px]">k commit</span><span class="text-ink">every <span class="text-ember">4</span> rounds</span></div>
            <div class="flex flex-col gap-0.5"><span class="text-ink-4 uppercase tracking-[0.18em] text-[9px]">finality</span><span class="text-ink">≈ <span class="text-ember">500</span> ms</span></div>
          </div>

          <div class="dag2-viz relative h-[230px]">
            <svg viewBox="0 0 420 240" class="block w-full h-full" aria-hidden="true">
              <!-- Top hairline + axis -->
              <line x1="20" y1="32" x2="400" y2="32" stroke="currentColor" stroke-width="0.4" class="text-rule-2"/>
              <line x1="20" y1="208" x2="400" y2="208" stroke="currentColor" stroke-width="0.4" class="text-rule-2"/>

              <!-- Reference arcs: r → r+1 (drawn as hairline beziers) -->
              <g stroke="currentColor" stroke-width="0.5" fill="none" class="text-cold/45" stroke-linecap="round">
                <!-- R → R+1 -->
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,55 C100,55 100,70 130,70"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,55 C100,55 100,100 130,100"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,85 C100,85 100,70 130,70"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,85 C100,85 100,100 130,100"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,85 C100,85 100,135 130,135"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,115 C100,115 100,70 130,70"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,115 C100,115 100,135 130,135"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,115 C100,115 100,165 130,165"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,150 C100,150 100,100 130,100"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,150 C100,150 100,135 130,135"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,150 C100,150 100,165 130,165"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,180 C100,180 100,135 130,135"/>
                <path class="dag2-edge" style="animation-delay:0.6s" d="M70,180 C100,180 100,165 130,165"/>

                <!-- R+1 → R+2 -->
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,70 C180,70 180,55 210,55"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,70 C180,70 180,90 210,90"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,100 C180,100 180,55 210,55"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,100 C180,100 180,90 210,90"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,100 C180,100 180,125 210,125"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,135 C180,135 180,90 210,90"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,135 C180,135 180,125 210,125"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,135 C180,135 180,160 210,160"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,165 C180,165 180,125 210,125"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,165 C180,165 180,160 210,160"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,165 C180,165 180,185 210,185"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,180 C180,180 180,160 210,160"/>
                <path class="dag2-edge" style="animation-delay:1.4s" d="M150,180 C180,180 180,185 210,185"/>

                <!-- R+2 → R+3 -->
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,55 C260,55 260,65 290,65"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,55 C260,55 260,95 290,95"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,90 C260,90 260,65 290,65"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,90 C260,90 260,95 290,95"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,90 C260,90 260,128 290,128"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,125 C260,125 260,95 290,95"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,125 C260,125 260,128 290,128"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,125 C260,125 260,158 290,158"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,160 C260,160 260,128 290,128"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,160 C260,160 260,158 290,158"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,160 C260,160 260,182 290,182"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,185 C260,185 260,158 290,158"/>
                <path class="dag2-edge" style="animation-delay:2.2s" d="M230,185 C260,185 260,182 290,182"/>

                <!-- R+3 → R+4 -->
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,65 C340,65 340,55 370,55"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,65 C340,65 340,90 370,90"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,95 C340,95 340,55 370,55"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,95 C340,95 340,90 370,90"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,95 C340,95 340,125 370,125"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,128 C340,128 340,90 370,90"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,128 C340,128 340,125 370,125"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,128 C340,128 340,160 370,160"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,158 C340,158 340,125 370,125"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,158 C340,158 340,160 370,160"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,158 C340,158 340,185 370,185"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,182 C340,182 340,160 370,160"/>
                <path class="dag2-edge" style="animation-delay:3.0s" d="M310,182 C340,182 340,185 370,185"/>
              </g>

              <!-- Vertices: 5 columns × 5 vertices -->
              <g class="dag2-verts">
                <!-- Round R (col 0, x=70) — delay 0s -->
                <circle cx="70" cy="55" r="2.5" class="dag2-vtx" style="--c:0"/>
                <circle cx="70" cy="85" r="2.5" class="dag2-vtx" style="--c:0"/>
                <circle cx="70" cy="115" r="2.5" class="dag2-vtx" style="--c:0"/>
                <circle cx="70" cy="150" r="2.5" class="dag2-vtx" style="--c:0"/>
                <circle cx="70" cy="180" r="2.5" class="dag2-vtx" style="--c:0"/>
                <!-- Round R+1 (x=140) -->
                <circle cx="140" cy="70" r="2.5" class="dag2-vtx" style="--c:1"/>
                <circle cx="140" cy="100" r="2.5" class="dag2-vtx" style="--c:1"/>
                <circle cx="140" cy="135" r="2.5" class="dag2-vtx" style="--c:1"/>
                <circle cx="140" cy="165" r="2.5" class="dag2-vtx" style="--c:1"/>
                <circle cx="140" cy="180" r="2.5" class="dag2-vtx" style="--c:1"/>
                <!-- Round R+2 (x=220) -->
                <circle cx="220" cy="55" r="2.5" class="dag2-vtx" style="--c:2"/>
                <circle cx="220" cy="90" r="2.5" class="dag2-vtx" style="--c:2"/>
                <circle cx="220" cy="125" r="2.5" class="dag2-vtx" style="--c:2"/>
                <circle cx="220" cy="160" r="2.5" class="dag2-vtx" style="--c:2"/>
                <circle cx="220" cy="185" r="2.5" class="dag2-vtx" style="--c:2"/>
                <!-- Round R+3 (x=300) -->
                <circle cx="300" cy="65" r="2.5" class="dag2-vtx" style="--c:3"/>
                <circle cx="300" cy="95" r="2.5" class="dag2-vtx" style="--c:3"/>
                <circle cx="300" cy="128" r="2.5" class="dag2-vtx" style="--c:3"/>
                <circle cx="300" cy="158" r="2.5" class="dag2-vtx" style="--c:3"/>
                <circle cx="300" cy="182" r="2.5" class="dag2-vtx" style="--c:3"/>
                <!-- Round R+4 (x=380) — leader / commit-wave round -->
                <circle cx="380" cy="55" r="2.5" class="dag2-vtx" style="--c:4"/>
                <circle cx="380" cy="90" r="2.5" class="dag2-vtx" style="--c:4"/>
                <circle cx="380" cy="125" r="2.5" class="dag2-vtx" style="--c:4"/>
                <circle cx="380" cy="160" r="2.5" class="dag2-vtx" style="--c:4"/>
                <circle cx="380" cy="185" r="2.5" class="dag2-vtx" style="--c:4"/>
              </g>

              <!-- Leader vertex highlight on R+4 (commit wave) -->
              <circle cx="380" cy="125" r="6" fill="none" stroke="#ff7d4d" stroke-width="0.7" class="dag2-leader" opacity="0"/>
              <text x="380" y="40" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="6.5" letter-spacing="1" fill="#ff7d4d" class="dag2-leader-label" opacity="0">leader</text>

              <!-- Commit wave (vertical glow line that sweeps) -->
              <line x1="0" y1="36" x2="0" y2="204" stroke="#ff7d4d" stroke-width="1" opacity="0" class="dag2-wave"/>

              <!-- Round labels (bottom) -->
              <g font-family="JetBrains Mono, monospace" font-size="7" letter-spacing="1.2" fill="currentColor" class="text-ink-3">
                <text x="70" y="222" text-anchor="middle">r</text>
                <text x="140" y="222" text-anchor="middle">r+1</text>
                <text x="220" y="222" text-anchor="middle">r+2</text>
                <text x="300" y="222" text-anchor="middle">r+3</text>
                <text x="380" y="222" text-anchor="middle">r+4</text>
              </g>

              <!-- Bottom annotation: relation -->
