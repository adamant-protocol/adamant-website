---
import HubLayout from '@/layouts/HubLayout.astro';
import { SEVEN_PROPERTIES, FIVE_MECHANISMS, UPDATES, PHASE, fmtAdm } from '@/data/chain';

const p = PHASE;
const burnRem = fmtAdm(p.genesisPool.burnRemaining);
const valRem = fmtAdm(p.genesisPool.validatorRemaining);

const COLS = ['BTC', 'ETH', 'XMR', 'ZEC', 'MINA', 'ADM'] as const;
const KEYS: Record<typeof COLS[number], keyof typeof SEVEN_PROPERTIES[0]['gap']> = {
  BTC: 'btc', ETH: 'eth', XMR: 'monero', ZEC: 'zec', MINA: 'mina', ADM: 'adm',
};

const latestUpdate = UPDATES[0];
---

<HubLayout active="home" title="Adamant — Home" description="A Layer 1 blockchain protocol. Privacy by default, post-quantum, no foundation, no premine, no admin keys.">

  <!-- HERO: chain status is the hero -->
  <section class="hero-state" data-screen-label="Hero · block height">
    <div class="container">
      <div class="eyebrow"><span class="num">§ 00</span> &nbsp; A Layer 1 blockchain protocol &nbsp; · &nbsp; Privacy by default &nbsp; · &nbsp; Post-quantum &nbsp; · &nbsp; No foundation, no premine</div>
      <div class="block-height">specification</div>
      <div class="hero-meta">
        <div class="left">
          <span class="label">Block height &nbsp; · &nbsp; {p.label}</span>
          <span class="serif" style="font-size: 22px; line-height: 1.4; color: var(--ink-2); max-width: 56ch;">
            {p.tagline}
          </span>
        </div>
        <div class="right">
          <span class="label">Identifier</span>
          <span class="mono" style="font-size:13px;color:var(--ink-2);">adamant/mainnet · chain-id 0x4d41 &nbsp; · &nbsp; spec v0.1</span>
          <span class="label" style="margin-top:8px;">Genesis pool</span>
          <span class="mono" style="font-size:18px;color:var(--ink);">
            {burnRem} <span style="color:var(--mute);">burn</span> · {valRem} <span style="color:var(--mute);">validator</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRIMARY ACTIONS -->
  <section data-screen-label="Primary actions">
    <div class="container" style="padding-top:24px; padding-bottom:24px;">
      <div class="actions">
        <a class="action is-disabled" href="#" data-action="acquire">
          <span class="label">Action 01</span>
          <span class="h">Acquire ADM</span>
          <span class="d">Burn BTC, ETH, USDT or USDC. 20 ADM minted per USD-equivalent burned.</span>
          <span class="arrow">Inactive · pre-launch</span>
        </a>
        <a class="action is-disabled" href="#" data-action="runner">
          <span class="label">Action 02</span>
          <span class="h">Become a Node Runner</span>
          <span class="d">Take a slot in the validator set. Stake floor 1 000 ADM. Cohort #1–75 are recognised permanently.</span>
          <span class="arrow">Inactive · pre-launch</span>
        </a>
        <a class="action is-disabled" href="#" data-action="watcher">
          <span class="label">Action 03</span>
          <span class="h">Become a Node Watcher</span>
          <span class="d">Attest, sample data availability, surface fraud. Stake floor 100 ADM. Uncapped set.</span>
          <span class="arrow">Inactive · pre-launch</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SEVEN-PROPERTIES GAP ANALYSIS -->
  <section class="section" data-screen-label="Seven properties · gap analysis">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 01</div>
        <div>
          <h2 class="title">The seven properties.</h2>
          <p class="subtitle">A base layer is only useful if it makes guarantees. These are the seven properties Adamant is built to provide. The cells below are abridged; full justification with citations lives in the <a class="link" href="https://github.com/adamant-protocol/adamant-website/tree/main/whitepaper" rel="noopener" target="_blank">whitepaper</a>.</p>
        </div>
      </div>

      <div class="props-row props-head">
        <div class="label">Property</div>
        <div class="label">Bitcoin</div>
        <div class="label">Ethereum</div>
        <div class="label">Monero</div>
        <div class="label">Zcash</div>
        <div class="label">Mina</div>
        <div class="label col-adm">Adamant</div>
      </div>

      {SEVEN_PROPERTIES.map((row) => (
        <div class="props-row">
          <div class="pcell k">
            <span class="name">{row.k}</span>
            <span class="note">{row.note}</span>
          </div>
          <div class="pcell center">{row.gap.btc ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.eth ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.monero ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.zec ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.mina ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center shade">{row.gap.adm ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
        </div>
      ))}

      <p class="small" style="margin-top:14px; max-width: 64ch;">
        ● = property satisfied. ○ = property absent or out of scope. The table is a summary; full justification with citations lives in the whitepaper.
      </p>
    </div>
  </section>

  <!-- FIVE MECHANISMS -->
  <section class="section" data-screen-label="Five mechanisms">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 02</div>
        <div>
          <h2 class="title">Five mechanisms.</h2>
          <p class="subtitle">The protocol is the composition of five mechanisms. Each is described in full in the whitepaper; summarised here.</p>
        </div>
      </div>
      <div class="mech-grid">
        {FIVE_MECHANISMS.map((m) => (
          <div class="mech">
            <span class="num">{m.num}</span>
            <span class="h">{m.name}</span>
            <span class="d">{m.d}</span>
            <span class="meta">{m.meta}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GENESIS COHORT PROGRESS -->
  <section class="section" data-screen-label="Genesis cohort progress">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 03</div>
        <div>
          <h2 class="title">Genesis cohort.</h2>
          <p class="subtitle">The first 75 validators form the genesis cohort. They are recognised by a permanent on-chain marker and a freely tradeable Genesis NFT. Slots are first-come, first-served. This grid fills in real time once the chain is live.</p>
        </div>
      </div>

      <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:14px;">
        <div class="mono" style="font-size: 13px; color: var(--ink-2);">
          <span>0</span><span style="color:var(--mute);"> / 75 slots taken</span>
        </div>
        <span class="mono" style="font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3);">
          Pre-launch · cohort opens at chain activation
        </span>
      </div>

      <div class="cohort" aria-label="Genesis cohort, 75 slots">
        {Array.from({ length: 75 }, (_, i) => i + 1).map((i) => (
          <div class="slot is-empty" title={`Cohort #${i}`}>
            <span class="n">#{String(i).padStart(2, '0')}</span>
          </div>
        ))}
      </div>

      <div style="display:flex; gap: 22px; margin-top: 14px; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.06em;">
        <span><span style="display:inline-block; width:6px; height:6px; background: var(--signal); margin-right: 6px;"></span>filled</span>
        <span><span style="display:inline-block; width:6px; height:6px; background: var(--ok); margin-right: 6px;"></span>active &amp; producing</span>
        <span><span style="display:inline-block; width:6px; height:6px; border:1px solid var(--rule-2); margin-right: 6px;"></span>open</span>
      </div>
    </div>
  </section>

  <!-- LATEST UPDATE -->
  <section class="section" data-screen-label="Latest update">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 04</div>
        <div>
          <h2 class="title">Latest from the journal.</h2>
          <p class="subtitle">Every design decision is logged. <a class="link" href="https://github.com/adamant-protocol/adamant-website/commits/main" rel="noopener" target="_blank">Open the full commit log →</a></p>
        </div>
      </div>

      <article style="display:grid; grid-template-columns: 220px 1fr; gap: 32px; padding-top: 8px; border-top: 1px solid var(--ink);">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <span class="label">{latestUpdate.date}</span>
          <span class="tag">{latestUpdate.tag}</span>
        </div>
        <div>
          <h3 class="serif" style="font-size: 28px; line-height: 1.1; letter-spacing: -0.015em;">{latestUpdate.title}</h3>
          <p class="serif" style="font-size: 17px; line-height: 1.5; color: var(--ink-2); max-width: 64ch; margin-top: 12px;">{latestUpdate.d}</p>
        </div>
      </article>
    </div>
  </section>

</HubLayout>
