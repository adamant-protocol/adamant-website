---
import Layout from '@/layouts/Layout.astro';
import WorldDive from '@/components/home/WorldDive.jsx';
import WarpField from '@/components/home/WarpField.jsx';
import PropertyMatrix from '@/components/home/PropertyMatrix.astro';
import Mechanisms from '@/components/home/Mechanisms.astro';
import Genesis from '@/components/home/Genesis.astro';
import TheatreTiers from '@/components/home/TheatreTiers.astro';
import Capabilities from '@/components/home/Capabilities.astro';
import PlainFramings from '@/components/home/PlainFramings.astro';
import NotThis from '@/components/home/NotThis.astro';
import Updates from '@/components/home/Updates.astro';
import { PHASE } from '@/data/chain';
---

<Layout
  active="home"
  title="Adamant — A Layer 1 protocol. Privacy by default. Governed by no one."
  description="A credibly neutral, privacy-default Layer 1 with DAG-BFT consensus, post-quantum cryptography, sub-second finality, and phone-verifiable state. Pre-launch."
  showTitleCard={true}
  showStatusStrip={false}
  showPhaseSwitcher={false}
  topPad={false}
>
  <!-- Cold-open hero: globe → city skyline dive -->
  <WorldDive client:load phase={PHASE} />

  <!-- Editorial sections -->
  <PropertyMatrix />
  <Mechanisms />

  <!-- Cinematic warp inter-tunnel — leads into tiers -->
  <WarpField client:visible height="200vh">
    <div class="warp-headline">— PROTOCOL → PARTICIPATION —</div>
    <div class="warp-big">
      <span class="it">Not a token launch.</span><br />
      A chain that asks who shows up.
    </div>
  </WarpField>

  <TheatreTiers />
  <Genesis />
  <Capabilities />
  <PlainFramings />
  <NotThis />
  <Updates />
</Layout>
