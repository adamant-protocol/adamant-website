---
import HubLayout from '@/layouts/HubLayout.astro';
import SeeAlso from '@/components/SeeAlso.astro';
import { SEVEN_PROPERTIES, CAPABILITIES, FIVE_MECHANISMS, PHASE, fmtAdm } from '@/data/chain';

const p = PHASE;
const burnRem = fmtAdm(p.genesisPool.burnRemaining);
const valRem = fmtAdm(p.genesisPool.validatorRemaining);

const CLAIM_STATES = [
  { k: 'Privacy', state: 'Specified', note: 'Default-shielded model and view-key disclosure are defined in the whitepaper.' },
  { k: 'Post-quantum', state: 'Specified', note: 'Hybrid signature and key-agreement primitives are selected, not yet audited in implementation.' },
  { k: 'Throughput', state: 'Pending benchmark', note: '50,000 TPS is the conservative design floor to prove during testnet.' },
  { k: 'Finality', state: 'Pending benchmark', note: 'Sub-second target depends on public testnet measurements.' },
  { k: 'Mempool integrity', state: 'Specified', note: 'Threshold encryption and VDF fallback regimes are described in the protocol spec.' },
  { k: 'Verifiability', state: 'Specified', note: 'Recursive verification design is documented; client implementation remains in progress.' },
  { k: 'Decentralisation', state: 'Operational target', note: 'Residential-fibre requirements are the launch constraint to validate.' },
];

const FLOW_STEPS = [
  { n: '01', h: 'Burn source asset', d: 'BTC, ETH, USDT or USDC leaves circulation through a verifiable burn path.' },
  { n: '02', h: 'Mint shielded ADM', d: 'The validator set verifies the burn proof and mints ADM to a private destination.' },
  { n: '03', h: 'Run the cohort', d: 'Node Runners and Watchers bring the active set above the safety floor.' },
  { n: '04', h: 'Verify locally', d: 'Recursive proofs let clients verify chain state without trusting an operator.' },
];
---

<HubLayout active="home" title="Adamant — Home" description="A Layer 1 blockchain protocol. Privacy by default, post-quantum, no foundation, no premine, no admin keys.">

  <!-- HERO: chain status is the hero. Pre-launch shows the genesis pool;
       once the chain is live the phase switcher swaps it for block height. -->
  <section class="hero-state">
    <div class="container">
      <div class="eyebrow"><span class="num">§ 00</span> &nbsp; A Layer 1 blockchain protocol &middot; Privacy by default &middot; Post-quantum &middot; No foundation, no premine</div>
      <h1 class="hero-title">Private, post-quantum settlement without an owner.</h1>
      <div class="hero-figure" id="home-hero-figure">100,000,000<span class="unit">ADM</span></div>
      <div class="hero-meta">
        <div class="left">
          <span class="label" id="home-hero-label">Genesis pool &nbsp; · &nbsp; {p.label}</span>
          <span class="serif" id="home-hero-tag" style="font-size: 22px; line-height: 1.4; color: var(--ink-2); max-width: 56ch;">
            {p.tagline}
          </span>
        </div>
        <div class="right">
          <span class="label">Identifier</span>
          <span class="mono" style="font-size:13px;color:var(--ink-2);">adamant/mainnet · chain-id 0x4d41 &nbsp; · &nbsp; spec v0.1</span>
          <span class="label" style="margin-top:8px;">Partition</span>
          <span class="mono" id="home-hero-partition" style="font-size:18px;color:var(--ink);">
            {burnRem} <span style="color:var(--mute);">burn</span> · {valRem} <span style="color:var(--mute);">validator</span>
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRIMARY ACTIONS -->
  <section data-screen-label="Primary actions">
    <div class="container" style="padding-top:24px; padding-bottom:24px;">
      <div class="actions">
        <a class="action" href="/spec" data-action="spec">
          <span class="label">Action 01</span>
          <span class="h">Read the specification</span>
          <span class="d">Start with the canonical whitepaper: protocol behaviour, assumptions, and launch constraints.</span>
          <span class="arrow">Open spec</span>
        </a>
        <a class="action" href="/genesis" data-action="genesis">
          <span class="label">Action 02</span>
          <span class="h">Review genesis mechanics</span>
          <span class="d">See how the 100M ADM pool drains through burn-to-mint and validator rewards.</span>
          <span class="arrow">Open genesis</span>
        </a>
        <a class="action" href="/updates" data-action="updates">
          <span class="label">Action 03</span>
          <span class="h">Follow implementation</span>
          <span class="d">Track material changes from the repository journal as the reference implementation progresses.</span>
          <span class="arrow">Open updates</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SEVEN-PROPERTIES GAP ANALYSIS -->
  <section class="section" data-screen-label="Seven properties · gap analysis">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 01</div>
        <div>
          <h2 class="title">The seven properties.</h2>
          <p class="subtitle">A base layer is only useful if it makes guarantees. These are the seven properties Adamant is built to provide. Each claim is marked by maturity so pre-launch reads as evidence, not theatre.</p>
        </div>
      </div>

      <div class="claim-grid" aria-label="Claim maturity">
        {CLAIM_STATES.map((claim, i) => (
          <article class="claim-card">
            <span class="num">{`M.${String(i + 1).padStart(2, '0')}`}</span>
            <h3>{claim.k}</h3>
            <span class="tag solid">{claim.state}</span>
            <p>{claim.note}</p>
          </article>
        ))}
      </div>

      <div class="props-row props-head">
        <div class="label">Property</div>
        <div class="label">Bitcoin</div>
        <div class="label">Ethereum</div>
        <div class="label">Monero</div>
        <div class="label">Zcash</div>
        <div class="label">Mina</div>
        <div class="label col-adm">Adamant</div>
      </div>

      {SEVEN_PROPERTIES.map((row) => (
        <div class="props-row">
          <div class="pcell k">
            <span class="name">{row.k}</span>
            <span class="note">{row.note}</span>
          </div>
          <div class="pcell center">{row.gap.btc ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.eth ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.monero ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.zec ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center">{row.gap.mina ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
          <div class="pcell center shade">{row.gap.adm ? <span class="gap-yes">●</span> : <span class="gap-no">○</span>}</div>
        </div>
      ))}

      <p class="small" style="margin-top:14px; max-width: 64ch;">
        ● = property satisfied. ○ = property absent or out of scope. The table is a summary; full justification with citations lives in the whitepaper.
      </p>
    </div>
  </section>

  <!-- WHAT YOU CAN BUILD -->
  <section class="section" data-screen-label="What you can build">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 02</div>
        <div>
          <h2 class="title">What you can build.</h2>
          <p class="subtitle">A base layer is only useful if it makes things possible. These are the capabilities Adamant's property combination opens.</p>
        </div>
      </div>
      <div class="caps-grid">
        {CAPABILITIES.map((c, i) => (
          <article class="cap">
            <span class="num">{`C.${String(i + 1).padStart(2, '0')}`}</span>
            <h3 class="cap-title">{c.title}</h3>
            <p class="cap-desc">{c.desc}</p>
            <p class="cap-eg"><span class="label">Examples</span>{c.eg}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FIVE MECHANISMS -->
  <section class="section" data-screen-label="Five mechanisms">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 03</div>
        <div>
          <h2 class="title">Five mechanisms.</h2>
          <p class="subtitle">The protocol is the composition of five mechanisms. Each is described in full in the whitepaper; summarised here.</p>
        </div>
      </div>
      <div class="mech-grid">
        {FIVE_MECHANISMS.map((m) => (
          <div class="mech">
            <span class="num">{m.num}</span>
            <span class="h">{m.name}</span>
            <span class="d">{m.d}</span>
            <span class="meta">{m.meta}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROTOCOL FLOW -->
  <section class="section" data-screen-label="Protocol flow">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 04</div>
        <div>
          <h2 class="title">From burn to verification.</h2>
          <p class="subtitle">The launch path in one operational view: supply enters through proof, the active set secures ordering, and clients verify the result locally.</p>
        </div>
      </div>

      <div class="flow-map" aria-label="Adamant protocol flow">
        {FLOW_STEPS.map((step) => (
          <article class="flow-step">
            <span class="flow-num">{step.n}</span>
            <h3>{step.h}</h3>
            <p>{step.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GENESIS COHORT PROGRESS -->
  <section class="section" data-screen-label="Genesis cohort progress">
    <div class="container">
      <div class="section-head">
        <div class="num-mark">§ 05</div>
        <div>
          <h2 class="title">Genesis cohort.</h2>
          <p class="subtitle">The first 75 validators form the genesis cohort. They are recognised by a permanent on-chain marker and a freely tradeable Genesis NFT. Slots are first-come, first-served. This grid fills in real time once the chain is live.</p>
        </div>
      </div>

      <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:14px;">
        <div class="mono" style="font-size: 13px; color: var(--ink-2);">
          <span>0</span><span style="color:var(--mute);"> / 75 slots taken</span>
        </div>
        <span class="mono" style="font-size: 11px; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-3);">
          Pre-launch · cohort opens at chain activation
        </span>
      </div>

      <div class="cohort" aria-label="Genesis cohort, 75 slots">
        {Array.from({ length: 75 }, (_, i) => i + 1).map((i) => (
          <div class="slot is-empty" title={`Cohort #${i}`}>
            <span class="n">#{String(i).padStart(2, '0')}</span>
          </div>
        ))}
      </div>

      <div style="display:flex; gap: 22px; margin-top: 14px; font-family: var(--mono); font-size: 11px; color: var(--ink-3); letter-spacing: 0.06em;">
        <span><span style="display:inline-block; width:6px; height:6px; background: var(--signal); margin-right: 6px;"></span>filled</span>
        <span><span style="display:inline-block; width:6px; height:6px; background: var(--ok); margin-right: 6px;"></span>active &amp; producing</span>
        <span><span style="display:inline-block; width:6px; height:6px; border:1px solid var(--rule-2); margin-right: 6px;"></span>open</span>
      </div>
    </div>
  </section>

  <SeeAlso current="home" />

</HubLayout>
