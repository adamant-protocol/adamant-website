  <style is:global>
    /* ───────── DAG consensus (Mechanism 01, refreshed) ───────── */
    /* Vertices: appear column-by-column, then "finalise" as the commit wave passes */
    @keyframes dag2-vtx-life {
      0%, 4%        { opacity: 0; transform: scale(0.6); fill: #2e3140; }
      8%, 50%       { opacity: 1; transform: scale(1);   fill: #c9c5b9; }
      62%, 92%      { opacity: 1; transform: scale(1.15); fill: #ff7d4d; }
      100%          { opacity: 0; transform: scale(0.6); fill: #2e3140; }
    }
    .dag2-vtx {
      transform-origin: center;
      transform-box: fill-box;
      animation: dag2-vtx-life 8s ease-in-out infinite;
      animation-delay: calc(var(--c, 0) * 0.4s);
    }
    /* Edges: hairlines that draw in once both endpoints are produced */
    @keyframes dag2-edge-draw {
      0%, 5%        { opacity: 0; stroke-dashoffset: 30; }
      15%, 50%      { opacity: 0.5; stroke-dashoffset: 0; }
      62%, 92%      { opacity: 0.22; stroke-dashoffset: 0; }
      100%          { opacity: 0; stroke-dashoffset: 30; }
    }
    .dag2-edge {
      stroke-dasharray: 30;
      stroke-dashoffset: 30;
      animation: dag2-edge-draw 8s ease-in-out infinite;
    }
    /* Commit wave: a vertical glow line that sweeps L→R every cycle */
    @keyframes dag2-wave-sweep {
      0%, 50%       { transform: translateX(0px);    opacity: 0; }
      55%           { transform: translateX(70px);   opacity: 0.9; }
      62%           { transform: translateX(140px);  opacity: 0.9; }
      72%           { transform: translateX(220px);  opacity: 0.9; }
      82%           { transform: translateX(300px);  opacity: 0.9; }
      90%           { transform: translateX(380px);  opacity: 0.6; }
      96%, 100%     { transform: translateX(380px);  opacity: 0; }
    }
    .dag2-wave {
      animation: dag2-wave-sweep 8s ease-in-out infinite;
      filter: drop-shadow(0 0 6px rgba(255,125,77,0.55));
      will-change: transform;
    }
    /* Leader (commit-vertex on round r+4) — appears at the end of the cycle */
    @keyframes dag2-leader-show {
      0%, 80%       { opacity: 0; transform: scale(0.5); }
      88%, 96%      { opacity: 1; transform: scale(1); }
      100%          { opacity: 0; transform: scale(1); }
    }
    .dag2-leader {
      transform-origin: 380px 125px;
      transform-box: view-box;
      animation: dag2-leader-show 8s ease-in-out infinite;
    }
    @keyframes dag2-leader-label-show {
      0%, 80%       { opacity: 0; }
      90%, 96%      { opacity: 0.9; }
      100%          { opacity: 0; }
    }
    .dag2-leader-label {
      animation: dag2-leader-label-show 8s ease-in-out infinite;
    }

    /* ───────── Encrypted mempool (Mechanism 02, refreshed) ───────── */
    /* Encrypted blobs appear staggered, then "decrypt" mid-cycle */
    @keyframes mp2-blob-enc-life {
      0%, 4%   { opacity: 0; transform: translateX(-12px); }
      10%, 50% { opacity: 1; transform: translateX(0); }
      55%, 70% { opacity: 0.35; }
      85%, 100% { opacity: 0; }
    }
    .mp2-blob-enc {
      transform-box: fill-box;
      animation: mp2-blob-enc-life 8s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * 0.18s);
    }
    /* Active keypers glow when threshold contributes */
    @keyframes mp2-keyper-active {
      0%, 40%  { opacity: 0.35; transform: scale(0.85); }
      50%, 75% { opacity: 1;    transform: scale(1.15); }
      85%, 100% { opacity: 0.35; transform: scale(0.85); }
    }
    .mp2-keyper-active {
      transform-origin: center;
      transform-box: fill-box;
      animation: mp2-keyper-active 8s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * 0.07s);
    }
    .mp2-keyper-idle { opacity: 0.3; }
    /* Share lines draw from keypers to decrypt point */
    @keyframes mp2-share-draw {
      0%, 40%  { stroke-dashoffset: 50; opacity: 0; }
      50%, 75% { stroke-dashoffset: 0; opacity: 0.8; }
      85%, 100% { stroke-dashoffset: 50; opacity: 0; }
    }
    .mp2-shares path {
      stroke-dasharray: 50;
      stroke-dashoffset: 50;
      animation: mp2-share-draw 8s ease-in-out infinite;
    }
    /* Decrypt point pulses ember when threshold reached */
    @keyframes mp2-decrypt-flash {
      0%, 50%  { opacity: 0; r: 2; }
      55%, 70% { opacity: 1; r: 4; }
      80%, 100% { opacity: 0; r: 2; }
    }
    .mp2-decrypt {
      animation: mp2-decrypt-flash 8s ease-in-out infinite;
      filter: drop-shadow(0 0 4px rgba(255,125,77,0.7));
    }
    /* Decrypted blobs appear after the threshold flash */
    @keyframes mp2-blob-dec-life {
      0%, 55%  { opacity: 0; transform: translateX(8px); }
      65%, 92% { opacity: 1; transform: translateX(0); }
      100%     { opacity: 0; transform: translateX(8px); }
    }
    .mp2-blob-dec {
      transform-box: fill-box;
      animation: mp2-blob-dec-life 8s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * 0.12s);
    }

    /* ───────── Recursive proof (Mechanism 03, refreshed) ───────── */
    @keyframes rp2-bar-pulse {
      0%, 100% { opacity: 0.45; }
      50%      { opacity: 0.85; }
    }
    .rp2-bar {
      animation: rp2-bar-pulse 5s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * 0.08s);
    }
    @keyframes rp2-tx-fade {
      0%, 30%  { opacity: 0; }
      40%, 65% { opacity: 0.7; }
      75%, 100% { opacity: 0.25; }
    }
    .rp2-tx {
      animation: rp2-tx-fade 5s ease-in-out infinite;
      animation-delay: calc(var(--i, 0) * 0.06s);
    }
    @keyframes rp2-pi-glow {
      0%, 65%  { opacity: 0.5; filter: drop-shadow(0 0 0 rgba(255,125,77,0)); }
      75%, 95% { opacity: 1;   filter: drop-shadow(0 0 6px rgba(255,125,77,0.55)); }
      100%     { opacity: 0.5; filter: drop-shadow(0 0 0 rgba(255,125,77,0)); }
    }
    .rp2-pi-glow {
      animation: rp2-pi-glow 5s ease-in-out infinite;
    }
    @keyframes rp2-spinner-show {
      0%, 60%  { opacity: 1; }
      80%, 100% { opacity: 0; }
    }
    .rp2-spinner {
      animation: rp2-spinner-show 5s linear infinite;
    }
    @keyframes rp2-spinner-rot {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(720deg); }
    }
    .rp2-spinner > circle {
      transform-origin: 383px 120px;
