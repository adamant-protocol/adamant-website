---
import Layout from '@/layouts/Layout.astro';
---
<Layout active="about" title="Adamant — License" description="Apache 2.0. Source and copy linked.">
  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ License · /license</div>
        <h1 class="title">Apache 2.0.</h1>
      </div>
      <div>
        <p class="lede">Every Adamant repository — protocol spec, reference node, reference wallet, this website — ships under Apache 2.0.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="claim-grid">
        <article class="claim-card"><span class="num">L.01</span><h3>You may</h3><p>Use, copy, modify, sublicense, distribute. Commercial or non-commercial. With or without source. Forever.</p></article>
        <article class="claim-card"><span class="num">L.02</span><h3>You must</h3><p>Preserve the copyright notice. State changes. Include the NOTICE file if there is one. License derivative work under terms compatible with Apache 2.0.</p></article>
        <article class="claim-card"><span class="num">L.03</span><h3>You don't</h3><p>Receive any warranty. There is no liability. The patent grant is limited to contributions; deliberate patent litigation revokes your patent license.</p></article>
      </div>
      <div style="margin-top: 28px; display:flex; gap: 12px; flex-wrap: wrap;">
        <a class="link mono small" href="https://github.com/adamant-protocol/adamant-website/blob/main/LICENSE" rel="noopener" target="_blank" style="border:1px solid var(--ink); padding:8px 14px; letter-spacing:0.10em; text-transform:uppercase;">Website LICENSE ↗</a>
        <a class="link mono small" href="https://www.apache.org/licenses/LICENSE-2.0" rel="noopener" target="_blank" style="border:1px solid var(--rule-2); padding:8px 14px; letter-spacing:0.10em; text-transform:uppercase;">Apache 2.0 text ↗</a>
      </div>
    </div>
  </section>
</Layout>
