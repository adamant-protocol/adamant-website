---
import Layout from '@/layouts/Layout.astro';
import ExplorerSearch from '@/components/ui/ExplorerSearch.astro';

export function getStaticPaths() {
  return Array.from({ length: 14 }, (_, i) => ({ params: { hash: String(i) } }));
}

const { hash } = Astro.params;
---
<Layout active="network" title={`Adamant — Tx ${hash}`} description="Per-transaction detail. Public envelope, validity proof, view-key disclosure widget.">
  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ Explorer · /network/tx/{hash}</div>
        <h1 class="title">Transaction <span class="mono" style="font-size:0.6em;">{hash}…</span></h1>
      </div>
      <div>
        <p class="lede">Two views of the same transaction. The <strong>public</strong> view is what every observer sees. The <strong>view-key</strong> view is what a holder of a scoped disclosure key can decrypt — by date range, amount, or counterparty (WP §7.4).</p>
        <div style="margin-top: 18px;"><ExplorerSearch /></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 32px;" class="net-grid">

        <!-- PUBLIC VIEW -->
        <div style="border: 1px solid var(--ink);">
          <div style="padding: 14px 18px; border-bottom: 1px solid var(--ink); background: var(--paper-2);"><span class="label">Public view · what every observer sees</span></div>
          {[
            ['TxHash', '—'],
            ['Block', '—'],
            ['Timestamp', '—'],
            ['Privacy', 'Shielded'],
            ['Encryption regime', 'Threshold / VDF'],
            ['Threshold-set indicator', '—'],
            ['Validity proof (Halo 2)', 'present'],
            ['Fee · compute', '—'],
            ['Fee · bandwidth', '—'],
            ['Fee · state', '—'],
            ['Finalisation status', 'pending'],
          ].map(([k, v]) => (
            <div style="display:grid; grid-template-columns: 220px 1fr; border-bottom: 1px solid var(--rule);" class="send-row">
              <div class="send-lab" style="padding: 12px 18px; border-right: 1px solid var(--rule);"><span class="label">{k}</span></div>
              <div class="send-val mono" style="padding: 12px 18px; font-size: 13px; color: var(--ink-2);">{v}</div>
            </div>
          ))}
        </div>

        <!-- VIEW KEY DISCLOSURE -->
        <div style="border: 1px solid var(--rule);">
          <div style="padding: 14px 18px; border-bottom: 1px solid var(--rule); background: var(--paper-2);"><span class="label">View-key disclosure · what a scoped key reveals</span></div>
          <div style="padding: 22px;">
            <p class="serif" style="font-size: 16px; line-height: 1.5; color: var(--ink-2); margin: 0 0 18px;">Paste a view key authorised for this transaction's scope. The chain has no idea who you are; it just decrypts.</p>
            <div style="display:flex; gap: 0; border: 1px solid var(--rule-2);">
              <input class="mono" placeholder="vkey1… (paste view key)" style="flex:1; border: 0; padding: 12px 14px; font-size: 13px; background: var(--paper); color: var(--ink-2); outline: none; min-width: 0;"/>
              <button class="mono" style="border: 0; border-left: 1px solid var(--rule-2); background: var(--ink); color: var(--paper); padding: 12px 16px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;">Disclose</button>
            </div>
            <p class="mono small" style="margin-top: 12px; color: var(--ink-3);">No view key? <a class="link" href="/wallet#view-keys">Learn how scoped disclosure works.</a></p>
            <div style="margin-top: 18px; padding: 14px; background: var(--paper-2); border-left: 2px solid var(--rule-2);">
              <div class="label">Decrypted fields (after disclosure)</div>
              <div class="mono small" style="color: var(--ink-3); margin-top: 8px;">Sender · Recipient · Amount · Memo · Object IDs touched</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
