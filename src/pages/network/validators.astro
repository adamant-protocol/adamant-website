---
import Layout from '@/layouts/Layout.astro';
import ExplorerSearch from '@/components/ui/ExplorerSearch.astro';
import DagBft from '@/components/diagrams/DagBft.astro';
---
<Layout active="network" title="Adamant — Validators" description="Active validator set, standby queue, registration order. Genesis cohort markers.">
  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ Explorer · /network/validators</div>
        <h1 class="title">Validator set.</h1>
      </div>
      <div>
        <p class="lede">Active set is dynamic: floor 7, soft ceiling 75. First-come, first-served with transferable membership. The first 75 to take active-set slots are the <strong>genesis cohort</strong> and receive a permanent marker plus a tradeable Genesis NFT.</p>
        <div style="margin-top: 18px;"><ExplorerSearch /></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink);" class="gn-cohort-stats">
        <div style="padding: 14px 18px;"><span class="label">Active</span><div class="mono" style="font-size: 28px; margin-top: 4px;">0 / 75</div></div>
        <div style="padding: 14px 18px; border-left: 1px solid var(--rule);"><span class="label">Standby queue</span><div class="mono" style="font-size: 28px; margin-top: 4px;">0</div></div>
        <div style="padding: 14px 18px; border-left: 1px solid var(--rule);"><span class="label">Security tier</span><div class="mono" style="font-size: 28px; margin-top: 4px;" data-spec="true">—</div></div>
        <div style="padding: 14px 18px; border-left: 1px solid var(--rule);"><span class="label">Cohort filled</span><div class="mono" style="font-size: 28px; margin-top: 4px;">0 / 75</div></div>
      </div>

      <DagBft />

      <div style="margin-top: 32px;" class="scroll-x">
        <table class="ledger">
          <thead>
            <tr>
              <th style="width: 56px;">#</th>
              <th>Address</th>
              <th class="r">Bonded</th>
              <th class="r">Delegated</th>
              <th class="r">Uptime · 7d</th>
              <th class="r">Latency</th>
              <th class="r">Rewards · ep</th>
              <th>Cohort</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="9" class="mono small" style="color: var(--ink-3); padding: 32px 16px; text-align:center; font-family: var(--serif); font-style: italic;">No validators yet — set begins forming at testnet activation.</td></tr>
          </tbody>
        </table>
      </div>

      <p class="small" style="margin-top: 16px;">Slots are transferable by mutual consent at an epoch boundary (WP §8.1.8); seniority preserved. The cohort marker is non-transferable and remains attached to the original address (WP §8.1.9).</p>
    </div>
  </section>
</Layout>
