---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Starfield from '@/components/Starfield.astro';
---

<BaseLayout
  active={null}
  title="404 — Not found"
  description="The page you tried to reach does not exist."
>
  <section class="relative min-h-[60vh] overflow-hidden flex items-center pt-10 md:pt-16 pb-20 md:pb-28">
    <Starfield />
    <div class="pointer-events-none absolute inset-0 z-[1] glow-pulse" style="background:radial-gradient(ellipse 70% 50% at 50% 45%, rgba(255,125,77,0.06), transparent 70%)"></div>

    <div class="wrap relative z-[3] w-full">
      <div class="grid items-center gap-10 md:gap-14 lg:grid-cols-[1.4fr_1fr]">
        <div data-reveal>
          <span class="eyebrow"><span class="dot"></span>HTTP 404 · resource not found</span>
          <h1 class="mt-6 max-w-[14ch] font-display font-medium leading-[0.98] tracking-[-0.035em]" style="font-size:clamp(56px,8vw,128px)">
            <span class="block font-light text-ink-2">Page</span>
            <span class="font-bold text-ember">not found.</span>
          </h1>
          <p class="mt-7 max-w-[44ch] text-[17px] leading-[1.7] text-ink-2">
            The requested resource does not exist on this site.
          </p>
          <div class="mt-11 flex flex-wrap gap-4">
            <a href="/" class="btn-link solid">Home <span class="arrow"></span></a>
            <a href="/about" class="btn-link">About <span class="arrow"></span></a>
            <a href="/spec" class="btn-link">Specification <span class="arrow"></span></a>
            <a href="/genesis" class="btn-link">Genesis <span class="arrow"></span></a>
          </div>
        </div>

        <div class="glass rounded-sm flex flex-col gap-4 p-6 md:p-8" data-reveal style="transition-delay:120ms">
          <div class="flex items-baseline justify-between border-b border-rule pb-3.5">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Status</span>
            <span class="font-mono text-[13px] text-ember tracking-[0.05em]">404</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-3.5">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Resource</span>
            <span class="font-mono text-[13px] text-ink tracking-[0.05em]">Not found</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-3.5">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">By design</span>
            <span class="font-mono text-[13px] text-ink-2 tracking-[0.05em]">No</span>
          </div>
          <div class="flex items-baseline justify-between">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Recoverable</span>
            <span class="font-mono text-[13px] text-ink tracking-[0.05em]">Yes</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
