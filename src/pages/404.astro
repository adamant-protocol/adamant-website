---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Starfield from '@/components/Starfield.astro';
---

<BaseLayout
  active={null}
  title="404 — Not found"
  description="The page you tried to reach does not exist."
>
  <section class="relative min-h-[80vh] overflow-hidden flex items-center pt-[80px] md:pt-[120px] pb-32">
    <Starfield />
    <div class="pointer-events-none absolute inset-0 z-[1]" style="background:radial-gradient(ellipse 70% 50% at 50% 45%, rgba(255,125,77,0.05), transparent 70%)"></div>

    <div class="wrap relative z-[3] w-full">
      <div class="grid items-end gap-16 lg:gap-24 lg:grid-cols-[1.4fr_1fr]">
        <div data-reveal>
          <span class="eyebrow"><span class="dot"></span>HTTP 404 · resource not found</span>
          <h1 class="mt-9 max-w-[14ch] font-display font-medium leading-none tracking-[-0.035em]" style="font-size:clamp(56px,8vw,128px)">
            <span class="block font-light text-ink-2">Not</span>
            <span class="font-bold text-ember">here.</span>
          </h1>
          <p class="mt-9 max-w-[48ch] text-[16.5px] leading-[1.7] text-ink-2">
            The page you tried doesn't exist. <span class="text-ink">Many things do not exist by design here</span> — no foundation, no admin keys, no premine, no upgrade authority. This particular absence is unintentional rather than principled, but the result is the same.
          </p>
          <div class="mt-11 flex flex-wrap gap-4">
            <a href="/" class="btn-link solid">Home <span class="arrow"></span></a>
            <a href="/about" class="btn-link">About <span class="arrow"></span></a>
            <a href="/spec" class="btn-link">Specification <span class="arrow"></span></a>
            <a href="/genesis" class="btn-link">Genesis <span class="arrow"></span></a>
          </div>
        </div>

        <div class="flex flex-col gap-5 pb-2" data-reveal style="transition-delay:120ms">
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Status</span>
            <span class="font-mono text-[13px] text-ember tracking-[0.05em]">404</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Resource</span>
            <span class="font-mono text-[13px] text-ink tracking-[0.05em]">Not found</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">By design</span>
            <span class="font-mono text-[13px] text-ink-2 tracking-[0.05em]">No</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-ink-3">Recoverable</span>
            <span class="font-mono text-[13px] text-ink tracking-[0.05em]">Yes</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
