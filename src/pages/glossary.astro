---
import Layout from '@/layouts/Layout.astro';
import SeeAlso from '@/components/ui/SeeAlso.astro';
import { GLOSSARY } from '@/data/chain';

const sorted = [...GLOSSARY].sort((a, b) => a.term.localeCompare(b.term));
---
<Layout active="about" title="Adamant — Glossary" description="Plain-language definitions of every term Adamant uses.">
  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ Glossary · /glossary</div>
        <h1 class="title">Glossary.</h1>
      </div>
      <div>
        <p class="lede">Every term Adamant uses, explained in one or two sentences. If a property cannot be explained without jargon, the property is not yet correctly stated (Principle VI).</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <dl class="gl-list">
        {sorted.map((g) => (
          <div class="gl-row">
            <dt class="serif gl-term">{g.term}</dt>
            <dd class="serif gl-def">{g.d}</dd>
          </div>
        ))}
      </dl>

      <style>
        .gl-list { margin: 0; padding: 0; border-top: 1px solid var(--ink); }
        .gl-row {
          display: grid;
          grid-template-columns: 240px 1fr;
          gap: 24px;
          padding: 18px 0;
          border-bottom: 1px solid var(--rule);
        }
        .gl-term { font-size: 20px; line-height: 1.2; letter-spacing: -0.005em; margin: 0; color: var(--ink); }
        .gl-def { margin: 0; font-size: 15.5px; line-height: 1.55; color: var(--ink-2); max-width: 70ch; }
        @media (max-width: 760px) {
          .gl-row { grid-template-columns: 1fr; gap: 6px; padding: 14px 0; }
          .gl-term { font-size: 18px; }
          .gl-def  { font-size: 14.5px; }
        }
      </style>
    </div>
  </section>

  <SeeAlso current="about" />
</Layout>
