---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Mark from '@/components/Mark.astro';
import Starfield from '@/components/Starfield.astro';
---

<BaseLayout
  active="genesis"
  title="Adamant — Genesis"
  description="How Adamant launches: a fixed 100M ADM genesis pool, partitioned 70/30, two acquisition paths, no premine, no foundation allocation."
>
  <!-- Hero -->
  <section class="relative overflow-hidden pt-[80px] md:pt-[120px] pb-16 md:pb-20">
    <Starfield />
    <div class="wrap relative z-[3]">
      <div class="grid items-end gap-24 lg:grid-cols-[1.4fr_1fr]">
        <div>
          <span class="eyebrow"><span class="dot"></span>Genesis · launch mechanism</span>
          <h1 class="mt-9 max-w-[14ch] font-display font-medium leading-none tracking-[-0.035em]" style="font-size:clamp(40px,5.5vw,84px)">
            <span class="block font-light text-ink-2">A fixed pool.</span>
            <span class="block font-semibold">Two paths in.</span>
            <span class="block font-bold text-ember">No master switch.</span>
          </h1>
          <p class="mt-9 max-w-[46ch] text-[16.5px] leading-[1.7] text-ink-2">
            Adamant launches with a fixed pool of 100,000,000 ADM. Seventy million is allocated to people who burn Bitcoin or Ether to mint it. Thirty million is earned by the validators who run the network. Whatever isn't claimed within five years is destroyed. There is no founder allocation. There is no foundation reserve.
          </p>
        </div>
        <div class="flex flex-col gap-5 pb-2">
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Pool size</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em]">100M<small class="ml-1.5 font-mono text-[10px] font-normal tracking-[0.16em] text-ink-3">ADM</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Path A · burn</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em]">70M<small class="ml-1.5 font-mono text-[10px] font-normal tracking-[0.16em] text-ink-3">70%</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Path B · validators</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em]">30M<small class="ml-1.5 font-mono text-[10px] font-normal tracking-[0.16em] text-ink-3">30%</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Time cap</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em]">5<small class="ml-1.5 font-mono text-[10px] font-normal tracking-[0.16em] text-ink-3">YEARS</small></span>
          </div>
          <div class="flex items-baseline justify-between border-b border-rule pb-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-3">Founder allocation</span>
            <span class="font-display text-[26px] font-medium leading-none tracking-[-0.025em] text-ember">0<small class="ml-1.5 font-mono text-[10px] font-normal tracking-[0.16em] text-ink-3">ZERO</small></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partition donut -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">§01 / THE POOL</span>
          <h2><span class="light">One hundred million,</span>partitioned at genesis.</h2>
        </div>
        <p class="desc">The full supply of ADM is set at genesis and minted as it's claimed. There is no token that exists before it is earned through one of the two paths.</p>
      </div>

      <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.2fr]">
        <div class="flex justify-center">
          <svg viewBox="0 0 400 400" class="max-w-[420px] w-full">
            <!-- Outer ring background -->
            <circle cx="200" cy="200" r="160" fill="none" stroke="rgba(236,232,223,0.06)" stroke-width="48" />
            <!-- Path A · 70% (ember) -->
            <circle cx="200" cy="200" r="160" fill="none" stroke="#ff7d4d" stroke-width="48" stroke-dasharray="703.7 1005.3" stroke-dashoffset="0" transform="rotate(-90 200 200)" />
            <!-- Path B · 30% (cold blue) -->
            <circle cx="200" cy="200" r="160" fill="none" stroke="#7da6ff" stroke-width="48" stroke-dasharray="301.6 1005.3" stroke-dashoffset="-703.7" transform="rotate(-90 200 200)" />
            <!-- Center labels -->
            <text x="200" y="190" text-anchor="middle" font-family="Unbounded" font-weight="500" font-size="42" fill="#ece8df" letter-spacing="-1.5">100M</text>
            <text x="200" y="220" text-anchor="middle" font-family="JetBrains Mono" font-size="11" fill="#5a5d6b" letter-spacing="3">ADM · FIXED</text>
          </svg>
        </div>

        <div class="flex flex-col gap-8">
          <div class="flex gap-5 border-l-2 border-ember pl-6" data-reveal>
            <div class="flex-1">
              <div class="mb-2 flex justify-between font-mono text-[11px] uppercase tracking-[0.2em]">
                <span class="text-ember">PATH A · BURN-TO-MINT</span>
                <span class="text-ink-2">70,000,000 ADM</span>
              </div>
              <p class="text-[14.5px] leading-[1.65] text-ink-2">Anyone who burns BTC or ETH to a verifiable null address can claim ADM at the protocol-defined rate. Mathematics; no permission needed. Per-address claim caps prevent early concentration.</p>
            </div>
          </div>

          <div class="flex gap-5 border-l-2 border-cold pl-6" data-reveal>
            <div class="flex-1">
              <div class="mb-2 flex justify-between font-mono text-[11px] uppercase tracking-[0.2em]">
                <span class="text-cold">PATH B · VALIDATOR REWARDS</span>
                <span class="text-ink-2">30,000,000 ADM</span>
              </div>
              <p class="text-[14.5px] leading-[1.65] text-ink-2">Earned block-by-block by the validators who actually run the chain. The only way to acquire stake from work, not capital. Calibrated to drain over the launch phase — a target of two to three years at single-digit ADM per block.</p>
            </div>
          </div>

          <div class="flex gap-5 border-l-2 border-ink-3 pl-6" data-reveal>
            <div class="flex-1">
              <div class="mb-2 flex justify-between font-mono text-[11px] uppercase tracking-[0.2em]">
                <span class="text-ink-3">UNCLAIMED · BURNED</span>
                <span class="text-ink-3">DESTROYED AT 5Y</span>
              </div>
              <p class="text-[14.5px] leading-[1.65] text-ink-2">If the pool is not exhausted within five years of genesis, the remainder is provably destroyed. The protocol does not retain it. The founders do not retain it. It simply ceases to exist.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Path A cap schedule -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">§02 / PATH A · CAP SCHEDULE</span>
          <h2><span class="light">Caps that lift</span>over twelve months.</h2>
        </div>
        <p class="desc">Per-address claim caps prevent the first hour from being dominated by a few large actors. The cap rises through five phases until it lifts entirely at month twelve.</p>
      </div>

      <div class="border border-rule-2 bg-bg-2 overflow-hidden">
        <div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-rule-2">
          {[
            { phase: 'Months 0–1', cap: '1%', desc: 'Tightest cap. The first month is for spreading distribution wide.' },
            { phase: 'Months 1–3', cap: '2%', desc: 'Slight relaxation as participation broadens.' },
            { phase: 'Months 3–6', cap: '4%', desc: 'Mid-launch. More room for committed holders.' },
            { phase: 'Months 6–12', cap: '8%', desc: 'Late launch. Caps still meaningful but minimal.' },
            { phase: 'Month 12+', cap: 'Uncapped', desc: 'Caps lift. Anyone can claim any amount.', em: true },
          ].map((p) => (
            <div class:list={['bg-bg-2 p-6 lg:p-7 flex flex-col gap-4 min-h-[200px] min-w-0 overflow-hidden', p.em && 'bg-bg-3']}>
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-ink-3">{p.phase}</span>
              <span
                class:list={[
                  'font-display font-medium leading-none tracking-[-0.03em] truncate',
                  p.em ? 'text-ember text-[clamp(28px,3.2vw,38px)]' : 'text-ink text-[clamp(34px,3.6vw,44px)]',
                ]}
              >{p.cap}</span>
              <p class="text-[12.5px] leading-[1.55] text-ink-2 mt-auto">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What is NOT happening -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <span class="num">§03 / WHAT IS NOT HAPPENING</span>
          <h2><span class="light">Notable absences,</span>by design.</h2>
        </div>
        <p class="desc">Most chain launches involve at least some of these. Adamant deliberately involves none of them. The negative space is the point.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-rule-2 border border-rule-2">
        {[
          ['No premine', 'No tokens exist before genesis. Not even one.'],
          ['No founder allocation', 'The implementers receive no ADM by virtue of having built it.'],
          ['No VC round', 'Nobody has invested cash in exchange for early tokens.'],
          ['No insider sale', 'There is no private round at a discount before public access.'],
          ['No foundation reserve', 'No pool of ADM held back for future protocol development.'],
          ['No vesting cliff', 'Because there is no allocation to vest.'],
          ['No bridge subsidy', 'No marketing fund. No incentive program. No liquidity mining.'],
          ['No retroactive airdrop', 'No reward for past activity on other chains.'],
        ].map(([t, p]) => (
          <div class="bg-bg-2 px-7 md:px-9 py-7 md:py-8 flex items-start gap-5 card-hover" data-reveal>
            <span class="font-mono text-[14px] text-ember leading-none mt-1">×</span>
            <div>
              <h4 class="font-display text-[18px] font-semibold tracking-[-0.015em] mb-1.5">{t}</h4>
              <p class="text-[13.5px] leading-[1.55] text-ink-2">{p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-40 text-center">
    <div class="wrap">
      <h2 class="mx-auto mb-10 max-w-[26ch] font-display font-medium leading-[1.05] tracking-[-0.03em]" style="font-size:clamp(32px,4.5vw,60px)">
        <span class="block font-light text-ink-2">The full mechanism is in</span>specification §10–11.
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/spec" class="btn-link solid">Read the spec <span class="arrow"></span></a>
        <a href="/about" class="btn-link">Plain-English version <span class="arrow"></span></a>
      </div>
    </div>
  </section>
</BaseLayout>
