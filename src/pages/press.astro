---
import Layout from '@/layouts/Layout.astro';
---
<Layout active="about" title="Adamant — Press kit" description="Logos, screenshots, colour tokens, talking points. Apache 2.0; honest framing preferred.">
  <section class="page-intro">
    <div class="container">
      <div>
        <div class="crumb">§ Press · /press</div>
        <h1 class="title">Press kit.</h1>
      </div>
      <div>
        <p class="lede">Logos in SVG, brand colour tokens, screenshots, one-liner descriptions. Use honestly. If you misrepresent the protocol, we won't sue — we'll just be sad.</p>
      </div>
    </div>
  </section>

  <!-- LOGOS -->
  <section class="section">
    <div class="container">
      <div class="section-head"><div class="num-mark">§ 01 / Marks</div><div><h2 class="title">Logos.</h2></div></div>
      <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--ink);" class="net-grid">
        {[
          { bg: 'var(--paper)', label: 'On paper'  },
          { bg: 'var(--paper-2)', label: 'On paper-2' },
          { bg: 'var(--ink)', label: 'On ink' },
        ].map((s, i) => (
          <div style={`padding: 36px; display: flex; align-items: center; justify-content: center; background: ${s.bg}; ${i > 0 ? 'border-left: 1px solid var(--rule);' : ''}`}>
            <img src="/adm-mark.svg" alt="Adamant mark" style={`width: 64px; height: 64px; ${i === 2 ? 'filter: invert(1);' : ''}`} />
          </div>
        ))}
      </div>
      <div style="margin-top: 18px; display:flex; gap: 12px; flex-wrap: wrap;">
        <a class="btn sm" href="/adm-mark.svg" download>Mark · SVG ↓</a>
      </div>
    </div>
  </section>

  <!-- COLOURS -->
  <section class="section">
    <div class="container">
      <div class="section-head"><div class="num-mark">§ 02 / Tokens</div><div><h2 class="title">Brand colour tokens.</h2></div></div>
      <div class="scroll-x">
        <table class="ledger">
          <thead><tr><th>Token</th><th>Role</th><th>Value</th></tr></thead>
          <tbody>
            <tr><td class="mono">--bg</td><td>Page background — onyx</td><td class="mono">#000000</td></tr>
            <tr><td class="mono">--ink</td><td>Primary text — white</td><td class="mono">#ffffff</td></tr>
            <tr><td class="mono">--ink-2</td><td>Body text</td><td class="mono">#d4d4d4</td></tr>
            <tr><td class="mono">--dim</td><td>De-emphasised text</td><td class="mono">#8e8e8e</td></tr>
            <tr><td class="mono">--faint</td><td>Faintest text / labels</td><td class="mono">#555555</td></tr>
            <tr><td class="mono">--line</td><td>Hairline rules</td><td class="mono">rgba(255,255,255,0.08)</td></tr>
            <tr><td class="mono">--accent</td><td>Section eyebrow / link hover</td><td class="mono">#ffffff</td></tr>
            <tr><td class="mono">--warn</td><td>Halted / critical</td><td class="mono">#ffffff</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- TALKING POINTS -->
  <section class="section">
    <div class="container">
      <div class="section-head"><div class="num-mark">§ 03 / Lines</div><div><h2 class="title">One-liners.</h2><p class="subtitle">Use whichever fits the audience. Don't add adjectives — the protocol does its own marketing.</p></div></div>
      <ul style="list-style: none; padding: 0; margin: 0;">
        {[
          'Adamant is a Layer 1 blockchain protocol. Privacy by default. Post-quantum. No foundation, no premine, no admin keys.',
          'A base layer that holds money — built on Halo 2 zero-knowledge proofs, ML-DSA post-quantum signatures, and a DAG-BFT consensus.',
          'Settlement on Adamant is private by default and selectively disclosable. Not "private when you ask"; private unless you choose otherwise.',
          '100M ADM genesis pool. Burn-to-mint plus validator emission. No allocation to anyone.',
          'A chain a phone can verify, a residential-fibre connection can validate, and a future quantum adversary cannot forge.',
        ].map((q, i) => (
          <li style="padding: 14px 0; border-top: 1px solid var(--rule);">
            <div class="mono small" style="color: var(--ink-3); letter-spacing: 0.10em;">L.{String(i+1).padStart(2,'0')}</div>
            <p class="serif" style="margin: 6px 0 0; font-size: 18px; line-height: 1.45; color: var(--ink); max-width: 64ch;">{q}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
